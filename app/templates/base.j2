{# templates/base.html #}
<!doctype html>
<html lang="it">

<head>
    <meta charset="utf-8">
    <title>{% block title %}Avanzamenti produzione{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="{{ url_for('static', filename='/assets/bootstrap/css/bootstrap.min.css')}}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    {% block extra_css %}{% endblock %}
</head>

<body>
    <header class="text-center min-vw-100 mh-100 m-auto mx-0" style="width: auto;height: auto;">
        <div class="container-fluid text-center d-flex w-100 h-100 flex-shrink-0 flex-fill justify-content-center align-items-center"
            style="width: auto;height: auto;">
            <div class="row d-inline-flex w-100 h-100 justify-content-center align-items-center align-self-center ms-0 me-0"
                style="width: auto;height: auto;">
                <div class="col-md-4 d-flex w-auto flex-grow-1 justify-content-start align-items-center pe-0"
                    style="width: auto;height: auto;"><button
                        class="btn btn-primary btn-lg text-center bg-light d-flex justify-content-center align-items-center"
                        type="button" data-bs-target="#offcanvas-2" data-bs-toggle="offcanvas"><svg
                            class="icon icon-tabler icon-tabler-menu-2 text-center text-black text-bg-light d-flex justify-content-center align-items-center"
                            xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"
                            stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round"
                            stroke-linejoin="round" style="font-size: 40px;">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                            <path d="M4 6l16 0"></path>
                            <path d="M4 12l16 0"></path>
                            <path d="M4 18l16 0"></path>
                        </svg></button></div>
                <div class="col-md-4 d-flex w-auto flex-grow-1 justify-content-center align-items-center"
                    style="width: auto;height: auto;">
                    {% if current_user.is_authenticated and current_user.genere == "m" %}
                    <h1 class="mb-0">{{current_user.reparto_label}}
                        - Benvenuto {{current_user.username}}</h1>
                    {% elif current_user.is_authenticated and current_user.genere == "f"%}
                    <h1 class="mb-0">{{current_user.reparto_label}}
                        - Benvenuta {{current_user.username}}</h1>
                    {% endif %}
                </div>
                <div class="col-md-4 d-flex w-auto flex-grow-1 justify-content-end align-items-center"
                    style="width: auto;height: auto;"><img
                        class="img-fluid justify-content-end align-items-center order-first" width="250" height="89"
                        src="{{ url_for('static', filename='/assets/img/logo.jpg')}}" style="text-align: right;" />
                </div>
            </div>
        </div>
    </header>
    {% include "partials/_nav_offcanvas.html" %}
    </div>
    {% block content %}{% endblock %}
    </main>

    <script src="{{ url_for('static', filename='assets/js/jquery.min.js')}}"></script>
    <script src="{{ url_for('static', filename='assets/bootstrap/js/bootstrap.min.js')}}"></script>
    <script src="{{ url_for('static', filename='assets/js/bs-init.js')}}"></script>
    {% block extra_js %}{% endblock %}
</body>

</html>