y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE &quot;input_odp_runtime_new&quot; (
	&quot;IdDocumento&quot; TEXT,
	&quot;IdRiga&quot; TEXT,
	&quot;RifRegistraz&quot; TEXT,
	&quot;Stato_odp&quot; TEXT,
	&quot;Data_in_carico&quot; TEXT,
	&quot;Tempo_funzionamento&quot; TEXT,
	&quot;Utente_operazione&quot; TEXT,
	&quot;Fase&quot; TEXT,
	&quot;data_ultima_attivazione&quot; TEXT,
	&quot;Note&quot; TEXT,
	&quot;QtyDaLavorare&quot; TEXT,
	&quot;RisorsaAttiva&quot; TEXT,
	&quot;LavorazioneAttiva&quot; TEXT,
	PRIMARY KEY(&quot;IdDocumento&quot;,&quot;IdRiga&quot;),
	FOREIGN KEY(&quot;IdDocumento&quot;,&quot;IdRiga&quot;) REFERENCES &quot;input_odp&quot;(&quot;IdDocumento&quot;,&quot;IdRiga&quot;) ON DELETE CASCADE

)</sql><current_tab id="0"/></tab_sql></sqlb_project>
