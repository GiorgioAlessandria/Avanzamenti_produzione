{% extends "base.j2" %}

{% block title %}Acquisti{% endblock %}

{% block content %}
    <main class="container-fluid mt-2 mb-3 d-flex flex-column px-0"
          id="acquisti-page"
          data-bridge-url="{{ url_for('main.api_acquisti_bridge') }}"
          style="height: calc(100vh - 140px); overflow: hidden; min-height: 0;">
        <div class="row g-3 flex-shrink-0">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body py-2">
                        <div class="align-items-center d-flex justify-content-between mb-0"
                             id="acquisti-section-switch">
                            <button class="btn btn-primary js-acq-section-btn active"
                                    type="button"
                                    data-section="giacenza">
                                Giacenza
                            </button>
                            <button class="btn btn-outline-primary js-acq-section-btn"
                                    type="button"
                                    data-section="materiale">
                                Materiale necessario
                            </button>
                            <button class="btn btn-outline-primary js-acq-section-btn"
                                    type="button"
                                    data-section="ordini">
                                Ordini produzione
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 flex-shrink-0">
                <section class="card shadow-sm"
                         id="acquisti-filters-container">
                    <div class="card-body py-2">
                        <div class="acq-filters-panel"
                             data-section="giacenza">
                            {% include "partials/_acquisti_filters_giacenza.j2" %}
                        </div>

                        <div class="acq-filters-panel d-none"
                             data-section="materiale">
                            {% include "partials/_acquisti_filters_materiale.j2" %}
                        </div>

                        <div class="acq-filters-panel d-none"
                             data-section="ordini">
                            {% include "partials/_acquisti_filters_ordini.j2" %}
                        </div>
                    </div>
                </section>
            </div>

            <div class="row g-3 flex-grow-1 mt-0 overflow-hidden"
                 style="min-height: 0;">
                <div class="col-12 h-100 overflow-hidden">
                    <section id="acquisti-content-container"
                             class="h-100 overflow-hidden"
                             style="min-height: 0;">
                        <div class="acq-section-panel h-100"
                             data-section="giacenza"
                             style="min-height: 0;">
                            {% include "partials/_acquisti_giacenza.j2" %}
                        </div>

                        <div class="acq-section-panel d-none h-100"
                             data-section="materiale"
                             style="min-height: 0;">
                            {% include "partials/_acquisti_materiale_necessario.j2" %}
                        </div>

                        <div class="acq-section-panel d-none h-100"
                             data-section="ordini"
                             style="min-height: 0;">
                            <div id="acquisti_ordini_section"
                                 class="h-100"
                                 style="min-height: 0;">
                                {% include "partials/_acquisti_ordini_produzione.j2" %}
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </main>

    <div class="modal fade"
         id="modalAcqMateriale"
         tabindex="-1"
         aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        Dettaglio materiale
                        <span id="modal-acq-materiale-title-extra"></span>
                    </h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div id="modal-acq-materiale-body"></div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block extra_js %}
    {{ super() }}
    <script>
        (() => {
            const sectionButtons = document.querySelectorAll(".js-acq-section-btn");
            const headerButtons = document.querySelectorAll(".js-acq-section-btn-base");
            const sectionPanels = document.querySelectorAll(".acq-section-panel");
            const filterPanels = document.querySelectorAll(".acq-filters-panel");

            function setButtonState(buttons, sectionName) {
                buttons.forEach((btn) => {
                    const isActive = btn.dataset.section === sectionName;
                    btn.classList.toggle("active", isActive);
                    btn.classList.toggle("btn-primary", isActive);
                    btn.classList.toggle("btn-outline-primary", !isActive);
                });
            }

            function setActiveSection(sectionName) {
                setButtonState(sectionButtons, sectionName);
                setButtonState(headerButtons, sectionName);

                sectionPanels.forEach((panel) => {
                    panel.classList.toggle("d-none", panel.dataset.section !== sectionName);
                });

                filterPanels.forEach((panel) => {
                    panel.classList.toggle("d-none", panel.dataset.section !== sectionName);
                });
            }

            [...sectionButtons, ...headerButtons].forEach((btn) => {
                btn.addEventListener("click", () => {
                    setActiveSection(btn.dataset.section);
                });
            });

            setActiveSection("giacenza");
        })();
        (() => {
            function applyAcqGiacenzaRowState() {
                const table = document.getElementById("acquisti_giacenza_table");
                if (!table) return;

                table.querySelectorAll("tbody tr").forEach((row) => {
                    row.classList.remove("row-acq-negative", "row-acq-understock");

                    const isNegative = (row.dataset.negative || "") === "1";
                    const isUnderstock = (row.dataset.understock || "") === "1";

                    // precedenza assoluta al negativo
                    if (isNegative) {
                        row.classList.add("row-acq-negative");
                    } else if (isUnderstock) {
                        row.classList.add("row-acq-understock");
                    }
                });
            }

            document.addEventListener("DOMContentLoaded", applyAcqGiacenzaRowState);
            window.applyAcqGiacenzaRowState = applyAcqGiacenzaRowState;
        })();
        (() => {
            document.addEventListener("DOMContentLoaded", () => {
                const root = document.getElementById("acquisti-page");
                if (!root) return;

                const bridgeUrl = root.dataset.bridgeUrl;
                if (!bridgeUrl) return;

                const POLL_MS = 30000;
                let isRefreshing = false;

                function getAcquistiFilterSnapshot() {
                    const snapshot = {};

                    document.querySelectorAll(
                        "#acquisti-filters-container .js-table-filter, " +
                        "#acquisti-filters-container .js-table-filter-checkbox"
                    ).forEach((el) => {
                        const key = el.id || `${el.dataset.targetTable || ""}|${el.dataset.filterKey || ""}`;
                        if (!key) return;

                        if (el.classList.contains("js-table-filter-checkbox")) {
                            snapshot[key] = Boolean(el.checked);
                        } else {
                            snapshot[key] = el.value ?? "";
                        }
                    });

                    return snapshot;
                }

                function restoreAcquistiFilterSnapshot(snapshot) {
                    document.querySelectorAll(
                        "#acquisti-filters-container .js-table-filter, " +
                        "#acquisti-filters-container .js-table-filter-checkbox"
                    ).forEach((el) => {
                        const key = el.id || `${el.dataset.targetTable || ""}|${el.dataset.filterKey || ""}`;
                        if (!key || !(key in snapshot)) return;

                        if (el.classList.contains("js-table-filter-checkbox")) {
                            el.checked = Boolean(snapshot[key]);
                        } else {
                            el.value = snapshot[key];
                        }
                    });
                }

                function getAllAcquistiTargetTableIds() {
                    const ids = new Set();

                    document.querySelectorAll(
                        "#acquisti-filters-container .js-table-filter[data-target-table], " +
                        "#acquisti-filters-container .js-table-filter-checkbox[data-target-table]"
                    ).forEach((el) => {
                        const tableId = (el.dataset.targetTable || "").trim();
                        if (tableId) ids.add(tableId);
                    });

                    return [...ids];
                }

                function parseDateDDMMYYYY(s) {
                    const m = String(s).trim().match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})(?:\s+(\d{1,2}):(\d{2}))?/);
                    if (!m) return NaN;
                    const dd = Number(m[1]);
                    const mm = Number(m[2]) - 1;
                    const yyyy = Number(m[3]);
                    const hh = m[4] ? Number(m[4]) : 0;
                    const mi = m[5] ? Number(m[5]) : 0;
                    return new Date(yyyy, mm, dd, hh, mi).getTime();
                }

                function guessType(value) {
                    const v = String(value).trim().replace(/\./g, "").replace(",", ".");
                    if (v === "") return "text";
                    if (!isNaN(Number(v))) return "num";
                    if (!isNaN(parseDateDDMMYYYY(value))) return "date";
                    return "text";
                }

                function cellValue(tr, colIndex) {
                    const td = tr.children[colIndex];
                    return td ? td.textContent.trim() : "";
                }

                function compareFactory(type, desc, colIndex) {
                    return (a, b) => {
                        const avRaw = cellValue(a, colIndex);
                        const bvRaw = cellValue(b, colIndex);

                        if (avRaw === "" && bvRaw === "") return 0;
                        if (avRaw === "") return 1;
                        if (bvRaw === "") return -1;

                        let res = 0;

                        if (type === "num") {
                            const av = Number(avRaw.replace(/\./g, "").replace(",", "."));
                            const bv = Number(bvRaw.replace(/\./g, "").replace(",", "."));
                            res = av - bv;
                        } else if (type === "date") {
                            const av = parseDateDDMMYYYY(avRaw);
                            const bv = parseDateDDMMYYYY(bvRaw);
                            res = av - bv;
                        } else {
                            res = avRaw.localeCompare(bvRaw, undefined, {
                                numeric: true,
                                sensitivity: "base",
                            });
                        }

                        return desc ? -res : res;
                    };
                }

                function getAcquistiSortSnapshot() {
                    const snapshot = {};

                    document.querySelectorAll("#acquisti-content-container table.table-sortable[id]").forEach((table) => {
                        const activeTh = table.querySelector("thead th[data-sort-dir]");
                        if (!activeTh) return;

                        const colIndex = activeTh.cellIndex;
                        const dir = activeTh.getAttribute("data-sort-dir");
                        const declaredType = (activeTh.getAttribute("data-sort") || "").toLowerCase();

                        let type = declaredType;
                        if (!type) {
                            const tbody = table.tBodies[0];
                            const rows = tbody ? Array.from(tbody.rows) : [];
                            const sample = rows.map((r) => cellValue(r, colIndex)).find((v) => v !== "") || "";
                            type = guessType(sample);
                        }

                        snapshot[table.id] = {
                            colIndex,
                            dir,
                            type,
                        };
                    });

                    return snapshot;
                }

                function restoreAcquistiSortSnapshot(snapshot) {
                    Object.entries(snapshot || {}).forEach(([tableId, meta]) => {
                        const table = document.getElementById(tableId);
                        if (!table) return;

                        const thead = table.tHead;
                        const tbody = table.tBodies[0];
                        if (!thead || !tbody) return;

                        const ths = Array.from(thead.querySelectorAll("th"));
                        ths.forEach((th, idx) => {
                            if (idx === meta.colIndex) {
                                th.setAttribute("data-sort-dir", meta.dir);
                            } else {
                                th.removeAttribute("data-sort-dir");
                            }
                        });

                        const rows = Array.from(tbody.rows);
                        const desc = meta.dir === "desc";

                        rows.sort(compareFactory(meta.type || "text", desc, meta.colIndex));
                        rows.forEach((row) => tbody.appendChild(row));
                    });
                }

                function reapplyAllAcquistiFilters() {
                    const tableIds = getAllAcquistiTargetTableIds();

                    tableIds.forEach((tableId) => {
                        window.applyFiltersToTable?.(tableId);
                    });

                    window.applyAcqGiacenzaRowState?.();
                    window.applyRowColors?.();
                    window.applyAcquistiOrdiniFilters?.();
                }

                async function refreshAcquistiTables() {
                    if (isRefreshing) return;

                    if (document.querySelector("#modalAcqMateriale.show")) {
                        return;
                    }

                    isRefreshing = true;
                    const filterSnapshot = getAcquistiFilterSnapshot();
                    const sortSnapshot = getAcquistiSortSnapshot();

                    try {
                        const response = await fetch(bridgeUrl, {
                            method: "GET",
                            headers: {
                                "Accept": "application/json",
                                "X-Requested-With": "XMLHttpRequest",
                            },
                            cache: "no-store",
                        });

                        if (!response.ok) return;

                        const data = await response.json();
                        if (!data || !data.ok) return;

                        const fragments = data.fragments || {};

                        Object.entries(fragments).forEach(([targetId, html]) => {
                            const target = document.getElementById(targetId);
                            if (target) {
                                target.innerHTML = html;
                            }
                        });

                        restoreAcquistiFilterSnapshot(filterSnapshot);
                        restoreAcquistiSortSnapshot(sortSnapshot);
                        reapplyAllAcquistiFilters();
                    } catch (err) {
                        console.error("Errore refresh acquisti:", err);
                    } finally {
                        isRefreshing = false;
                    }
                }

                window.refreshAcquistiTables = refreshAcquistiTables;
                window.setInterval(refreshAcquistiTables, POLL_MS);

                // opzionale ma utile anche al primo caricamento
                reapplyAllAcquistiFilters();
            });
        })();
    </script>
    <script>
        (() => {
            document.addEventListener("DOMContentLoaded", () => {
                const sourceInput = document.getElementById("filter-acq-ordini-rifglobale");
                if (!sourceInput) return;

                const hiddenFilterIds = [
                    "filter-acq-ordini-rif-montaggio-sl",
                    "filter-acq-ordini-rif-montaggio-m",
                    "filter-acq-ordini-rif-officina",
                    "filter-acq-ordini-rif-carpenteria",
                ];

                const orderTableIds = [
                    "acquisti_ordini_montaggio_sl_table",
                    "acquisti_ordini_montaggio_m_table",
                    "acquisti_ordini_officina_table",
                    "acquisti_ordini_carpenteria_table",
                ];

                function applyAcquistiOrdiniFilters() {
                    const value = sourceInput.value || "";

                    hiddenFilterIds.forEach((id) => {
                        const hiddenInput = document.getElementById(id);
                        if (hiddenInput) hiddenInput.value = value;
                    });

                    orderTableIds.forEach((tableId) => {
                        window.applyFiltersToTable?.(tableId);
                    });
                }

                sourceInput.addEventListener("input", applyAcquistiOrdiniFilters);
                window.applyAcquistiOrdiniFilters = applyAcquistiOrdiniFilters;

                applyAcquistiOrdiniFilters();
            });
        })();
    </script>
    <script>
        (() => {
            function escHtml(value) {
                return String(value ?? "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function renderEmptyState(message) {
                return `<div class="text-muted">${escHtml(message)}</div>`;
            }

            function renderRowsTable(title, rows, columns) {
                if (!Array.isArray(rows) || rows.length === 0) {
                    return `
                    <div class="mb-3">
                        <h6 class="mb-2">${escHtml(title)}</h6>
                        ${renderEmptyState("Nessun dato disponibile.")}
                    </div>
                `;
                }

                const thead = columns.map(col => `<th>${escHtml(col.label)}</th>`).join("");
                const tbody = rows.map(row => {
                    const tds = columns.map(col => `<td>${escHtml(row?.[col.key] ?? "")}</td>`).join("");
                    return `<tr>${tds}</tr>`;
                }).join("");

                return `
                <div class="mb-3">
                    <h6 class="mb-2">${escHtml(title)}</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped table-hover align-middle mb-0">
                            <thead>
                                <tr>${thead}</tr>
                            </thead>
                            <tbody>
                                ${tbody}
                            </tbody>
                        </table>
                    </div>
                </div>
            `;
            }

            document.addEventListener("click", (event) => {
                const btn = event.target.closest(".js-open-acq-material-modal");
                if (!btn) return;

                const modalEl = document.getElementById("modalAcqMateriale");
                const titleExtraEl = document.getElementById("modal-acq-materiale-title-extra");
                const bodyEl = document.getElementById("modal-acq-materiale-body");

                if (!modalEl || !titleExtraEl || !bodyEl) return;

                let payload = {};
                try {
                    payload = JSON.parse(btn.dataset.material || "{}");
                } catch (err) {
                    console.error("Payload modal materiale non valido:", err);
                    titleExtraEl.textContent = "";
                    bodyEl.innerHTML = `<div class="alert alert-danger mb-0">Impossibile leggere il dettaglio materiale.</div>`;
                    bootstrap.Modal.getOrCreateInstance(modalEl).show();
                    return;
                }

                const codArt = payload.cod_art || "";
                const variante = payload.variante_art || "";
                const desArt = payload.des_art || "";
                const magUm = payload.mag_um || "";

                titleExtraEl.textContent = [codArt, variante].filter(Boolean).join(" - ");

                const headerInfo = `
                <div class="mb-3">
                    <div><strong>Codice:</strong> ${escHtml(codArt || "-")}</div>
                    <div><strong>Variante:</strong> ${escHtml(variante || "-")}</div>
                    <div><strong>Descrizione:</strong> ${escHtml(desArt || "-")}</div>
                    <div><strong>UdM:</strong> ${escHtml(magUm || "-")}</div>
                </div>
            `;

                const distintaHtml = renderRowsTable(
                    "Impeghi in distinta",
                    payload.in_distinta || [],
                    [
                        {key: "Ordine", label: "Ordine"},
                        {key: "DescrizioneOrdine", label: "Descrizione ordine"},
                        {key: "Stato", label: "Stato"},
                        {key: "Fase", label: "Fase"},
                        {key: "Quantita", label: "Quantità"},
                        {key: "MagUM", label: "UdM"},
                    ]
                );

                const ordineHtml = renderRowsTable(
                    "Produzione prevista",
                    payload.in_ordine || [],
                    [
                        {key: "Ordine", label: "Ordine"},
                        {key: "DescrizioneOrdine", label: "Descrizione ordine"},
                        {key: "Stato", label: "Stato"},
                        {key: "Quantita", label: "Quantità"},
                        {key: "Tipo", label: "Tipo"},
                    ]
                );

                bodyEl.innerHTML = headerInfo + distintaHtml + ordineHtml;

                bootstrap.Modal.getOrCreateInstance(modalEl).show();
            });
        })();
    </script>
{% endblock %}