{% extends "base.j2" %}

{% block title %}Acquisti{% endblock %}

{% block content %}
    <main class="container-fluid mt-2 mb-3 d-flex flex-column"
          id="acquisti-page"
          style="height: calc(100vh - 140px); overflow: hidden;">
        <div class="row g-3 flex-shrink-0">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body py-2">
                        <div class="align-items-center d-flex justify-content-between mb-0"
                             id="acquisti-section-switch">
                            <button class="btn btn-primary js-acq-section-btn active"
                                    type="button"
                                    data-section="giacenza">
                                Giacenza
                            </button>
                            <button class="btn btn-outline-primary js-acq-section-btn"
                                    type="button"
                                    data-section="materiale">
                                Materiale necessario
                            </button>
                            <button class="btn btn-outline-primary js-acq-section-btn"
                                    type="button"
                                    data-section="ordini">
                                Ordini produzione
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 flex-shrink-0">
                <section class="card shadow-sm"
                         id="acquisti-filters-container">
                    <div class="card-body py-2">
                        <div class="acq-filters-panel"
                             data-section="giacenza">
                            {% include "partials/_acquisti_filters_giacenza.j2" %}
                        </div>

                        <div class="acq-section-panel d-none h-100"
                             data-section="materiale">
                            {% include "partials/_acquisti_filters_materiale.j2" %}
                        </div>

                        <div class="acq-filters-panel d-none"
                             data-section="ordini">
                            <div class="text-muted">Filtri ordini di produzione da definire.</div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <div class="row g-3 flex-grow-1 mt-0 overflow-hidden">
            <div class="col-12 h-100">
                <section id="acquisti-content-container"
                         class="h-100">
                    <div class="acq-section-panel h-100"
                         data-section="giacenza">
                        {% include "partials/_acquisti_giacenza.j2" %}
                    </div>

                    <div class="acq-section-panel d-none h-100"
                         data-section="materiale">
                        <div class="card shadow-sm h-100">
                            <div class="acq-section-panel d-none h-100"
                                 data-section="materiale">
                                {% include "partials/_acquisti_materiale_necessario.j2" %}
                            </div>
                        </div>
                    </div>

                    <div class="acq-section-panel d-none h-100"
                         data-section="ordini">
                        <div class="card shadow-sm h-100">
                            <div class="card-body">
                                <h2 class="h4 mb-2">Ordini di produzione</h2>
                                <p class="text-muted mb-0">Sezione in preparazione.</p>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>

    <div class="modal fade"
         id="modalAcqMateriale"
         tabindex="-1"
         aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        Dettaglio materiale
                        <span id="modal-acq-materiale-title-extra"></span>
                    </h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div id="modal-acq-materiale-body"></div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block extra_js %}
    {{ super() }}
    <script>
        (() => {
            const sectionButtons = document.querySelectorAll(".js-acq-section-btn");
            const headerButtons = document.querySelectorAll(".js-acq-section-btn-base");
            const sectionPanels = document.querySelectorAll(".acq-section-panel");
            const filterPanels = document.querySelectorAll(".acq-filters-panel");

            function setButtonState(buttons, sectionName) {
                buttons.forEach((btn) => {
                    const isActive = btn.dataset.section === sectionName;
                    btn.classList.toggle("active", isActive);
                    btn.classList.toggle("btn-primary", isActive);
                    btn.classList.toggle("btn-outline-primary", !isActive);
                });
            }

            function setActiveSection(sectionName) {
                setButtonState(sectionButtons, sectionName);
                setButtonState(headerButtons, sectionName);

                sectionPanels.forEach((panel) => {
                    panel.classList.toggle("d-none", panel.dataset.section !== sectionName);
                });

                filterPanels.forEach((panel) => {
                    panel.classList.toggle("d-none", panel.dataset.section !== sectionName);
                });
            }

            [...sectionButtons, ...headerButtons].forEach((btn) => {
                btn.addEventListener("click", () => {
                    setActiveSection(btn.dataset.section);
                });
            });

            setActiveSection("giacenza");
        })();
        (() => {
            function applyAcqGiacenzaRowState() {
                const table = document.getElementById("acquisti_giacenza_table");
                if (!table) return;

                table.querySelectorAll("tbody tr").forEach((row) => {
                    row.classList.remove("row-acq-negative", "row-acq-understock");

                    const isNegative = (row.dataset.negative || "") === "1";
                    const isUnderstock = (row.dataset.understock || "") === "1";

                    // precedenza assoluta al negativo
                    if (isNegative) {
                        row.classList.add("row-acq-negative");
                    } else if (isUnderstock) {
                        row.classList.add("row-acq-understock");
                    }
                });
            }

            document.addEventListener("DOMContentLoaded", applyAcqGiacenzaRowState);
            window.applyAcqGiacenzaRowState = applyAcqGiacenzaRowState;
        })();
        (() => {
            document.addEventListener("DOMContentLoaded", () => {
                const modalEl = document.getElementById("modalAcqMateriale");
                const modalBody = document.getElementById("modal-acq-materiale-body");
                const modalTitleExtra = document.getElementById("modal-acq-materiale-title-extra");

                if (!modalEl || !modalBody || !modalTitleExtra) return;

                function escapeHtml(value) {
                    return String(value || "")
                        .replaceAll("&", "&amp;")
                        .replaceAll("<", "&lt;")
                        .replaceAll(">", "&gt;")
                        .replaceAll('"', "&quot;")
                        .replaceAll("'", "&#039;");
                }

                function renderTable(rows, columns) {
                    if (!rows || !rows.length) {
                        return `<div class="text-muted">Nessuna riga presente.</div>`;
                    }

                    const thead = columns
                        .map(col => `<th>${escapeHtml(col.label)}</th>`)
                        .join("");

                    const tbody = rows
                        .map((row) => {
                            const tds = columns
                                .map(col => `<td>${escapeHtml(row[col.key] ?? "")}</td>`)
                                .join("");
                            return `<tr>${tds}</tr>`;
                        })
                        .join("");

                    return `
                    <div class="table-responsive">
                        <table class="table table-sm table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>${thead}</tr>
                            </thead>
                            <tbody>${tbody}</tbody>
                        </table>
                    </div>
                `;
                }

                document.addEventListener("click", (event) => {
                    const btn = event.target.closest(".js-open-acq-material-modal");
                    if (!btn) return;

                    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

                    const raw = btn.getAttribute("data-material") || "{}";
                    let payload = {};

                    try {
                        payload = JSON.parse(raw);
                    } catch (err) {
                        console.error(err);
                        modalTitleExtra.textContent = "";
                        modalBody.innerHTML = `<div class="alert alert-danger mb-0">Errore nel dettaglio materiale.</div>`;
                        modal.show();
                        return;
                    }

                    const codArt = payload.cod_art || "";
                    const variante = payload.variante_art || "";
                    const desArt = payload.des_art || "";

                    const titolo = [codArt, variante].filter(Boolean).join(" - ");
                    modalTitleExtra.textContent = titolo ? `- ${titolo}` : "";

                    const distintaHtml = renderTable(
                        payload.in_distinta || [],
                        [
                            {key: "Ordine", label: "Ordine"},
                            {key: "Stato", label: "Stato"},
                            {key: "Fase", label: "Fase"},
                            {key: "Quantita", label: "Quantità"},
                            {key: "DescrizioneOrdine", label: "Articolo ordine"},
                        ]
                    );

                    const ordineHtml = renderTable(
                        payload.in_ordine || [],
                        [
                            {key: "Ordine", label: "Ordine"},
                            {key: "Stato", label: "Stato"},
                            {key: "Quantita", label: "Quantità residua"},
                            {key: "DescrizioneOrdine", label: "Articolo ordine"},
                        ]
                    );

                    modalBody.innerHTML = `
                    <div class="mb-3">
                        <div><strong>Codice:</strong> ${escapeHtml(codArt)}</div>
                        <div><strong>Variante:</strong> ${escapeHtml(variante)}</div>
                        <div><strong>Descrizione:</strong> ${escapeHtml(desArt)}</div>
                    </div>

                    <div class="mb-4">
                        <h6 class="mb-2">Presente in distinta base</h6>
                        ${distintaHtml}
                    </div>

                    <div>
                        <h6 class="mb-2">Presente come articolo ordine</h6>
                        ${ordineHtml}
                    </div>
                `;

                    modal.show();
                });
            });
        })();
    </script>
{% endblock %}