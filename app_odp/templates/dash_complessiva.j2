{% extends "base.j2" %}

{% block title %}Dashboard complessiva{% endblock %}

{% block content %}
    <main class="container-fluid mt-4 mb-4">
        <div class="row g-4">

            <!-- Reparti a destra -->
            <div class="col-12 col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <h3 class="mb-0">Selezione reparto</h3>
                    </div>
                    <div class="card-body">
                        {% if kpi_reparti %}
                            <div class="list-group"
                                 id="dash-complessiva-reparti-list">
                                {% for reparto in kpi_reparti %}
                                    <button type="button"
                                            class="list-group-item list-group-item-action js-select-reparto"
                                            data-reparto="{{ reparto.codice }}">
                                        <div class="d-flex justify-content-between align-items-center gap-2">
                                            <span class="fw-semibold">{{ reparto.descrizione }}</span>
                                            <span class="badge text-bg-light">{{ reparto.kpi.totali }} ordini</span>
                                        </div>
                                    </button>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="alert alert-secondary mb-0">
                                Nessun reparto disponibile nel tuo perimetro.
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            <!-- KPI a sinistra -->
            <div class="col-12 col-lg-8">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <h3 class="mb-0">Dashboard complessiva</h3>
                    </div>
                    <div class="card-body"
                         id="dash-complessiva-dettaglio"></div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}

{% block extra_js %}
    {{ super() }}

    <script id="dash-complessiva-global-kpi"
            type="application/json">{{ kpi_globali|tojson }}</script>
    <script id="dash-complessiva-reparti-kpi"
            type="application/json">{{ kpi_reparti|tojson }}</script>

    <script>
        (() => {
            const globalEl = document.getElementById("dash-complessiva-global-kpi");
            const repartiEl = document.getElementById("dash-complessiva-reparti-kpi");
            const detail = document.getElementById("dash-complessiva-dettaglio");
            const repartiButtons = document.querySelectorAll(".js-select-reparto");

            let globalKpi = {};
            let repartiKpi = [];

            try {
                globalKpi = JSON.parse(globalEl?.textContent || "{}");
            } catch (_) {
                globalKpi = {};
            }

            try {
                repartiKpi = JSON.parse(repartiEl?.textContent || "[]");
            } catch (_) {
                repartiKpi = [];
            }

            function escapeHtml(value) {
                return String(value ?? "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function totalKpiCard(title, value, tone = "secondary") {
                const borderClass = {
                    primary: "border-primary",
                    warning: "border-warning",
                    success: "border-success",
                    secondary: "border-secondary",
                }[tone] || "border-secondary";

                return `
                        <div class="col-12 col-lg-4">
                            <div class="card h-100 border-start border-4 ${borderClass} shadow-sm bg-light">
                                <div class="card-body py-3 px-3">
                                    <div class="text-muted"
                                         style="font-size: 0.95rem; line-height: 1.15;">
                                        ${escapeHtml(title)}
                                    </div>
                                    <div class="fw-semibold mt-2"
                                         style="font-size: 1.35rem; line-height: 1.1;">
                                        ${escapeHtml(value)}
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
            }

            function compactKpiCard(title, value, tone = "secondary") {
                const borderClass = {
                    primary: "border-primary",
                    warning: "border-warning",
                    success: "border-success",
                    secondary: "border-secondary",
                }[tone] || "border-secondary";

                return `
        <div class="col-6 col-xl">
            <div class="card h-100 border-start border-4 ${borderClass} shadow-sm bg-light">
                <div class="card-body py-2 px-2">
                    <div class="text-muted"
                         style="font-size: 0.78rem; line-height: 1.1;">
                        ${escapeHtml(title)}
                    </div>
                    <div class="fw-semibold mt-1"
                         style="font-size: 1rem; line-height: 1.1;">
                        ${escapeHtml(value)}
                    </div>
                </div>
            </div>
        </div>
    `;
            }

            function formatMinutes(value) {
                const num = Number(value || 0);
                return Number.isInteger(num) ? `${num} min` : `${num.toFixed(2)} min`;
            }

            function formatHours(value) {
                const num = Number(value || 0);
                return Number.isInteger(num) ? `${num} h` : `${num.toFixed(2)} h`;
            }

            function formatDays(value) {
                const num = Number(value || 0);
                return Number.isInteger(num) ? `${num} gg` : `${num.toFixed(2)} gg`;
            }

            function renderKpiGrid(kpi) {
                return `
                <div class="row g-3 mb-3">
                    ${totalKpiCard("Ordini totali", kpi.totali || 0, "secondary")}
                    ${totalKpiCard("Giorni ordini attivi", formatDays(kpi.giorni_impegno_attivi), "success")}
                    ${totalKpiCard("Giorni ordini sospesi", formatDays(kpi.giorni_impegno_sospesi), "warning")}
                </div>

                <div class="row g-3 mb-3">
                    ${compactKpiCard("Ordini pianificati", kpi.pianificati || 0, "primary")}
                    ${compactKpiCard("Ordini attivi", kpi.attivi || 0, "success")}
                    ${compactKpiCard("Ordini sospesi", kpi.sospesi || 0, "warning")}
                </div>

                <div class="row g-3 mb-3">
                    ${compactKpiCard("Ore ordini pianificati", formatHours(kpi.ore_ordini_pianificati), "primary")}
                    ${compactKpiCard("Ore ordini attivi", formatHours(kpi.ore_ordini_attivi), "success")}
                    ${compactKpiCard("Ore ordini sospesi", formatHours(kpi.ore_ordini_sospesi), "warning")}
                </div>

                <div class="row g-3">
                    ${compactKpiCard("Ore attrezzaggio ordini pianificati", formatHours(kpi.ore_attrezzaggio_ordini_pianificati), "primary")}
                    ${compactKpiCard("Ore attrezzaggio ordini attivi", formatHours(kpi.ore_attrezzaggio_ordini_attivi), "success")}
                    ${compactKpiCard("Ore attrezzaggio ordini sospesi", formatHours(kpi.ore_attrezzaggio_ordini_sospesi), "warning")}
                </div>
            `;
            }

            function renderPage(repartoCode = "") {
                const reparto = repartiKpi.find((item) => item.codice === repartoCode);
                const repartoLabel = reparto
                    ? reparto.descrizione
                    : "Nessun reparto selezionato";

                detail.innerHTML = `
                    <div class="mb-4">
                        <h4 class="mb-3">KPI globali</h4>
                        ${renderKpiGrid(globalKpi)}
                    </div>

                    <div>
                        <h4 class="mb-3">KPI reparto selezionato: ${escapeHtml(repartoLabel)}</h4>
                        ${
                    reparto
                        ? renderKpiGrid(reparto.kpi || {})
                        : '<div class="alert alert-info mb-0">Seleziona un reparto a destra per visualizzare i KPI di reparto.</div>'
                }
                    </div>
                `;
            }

            function setActiveButton(repartoCode = "") {
                repartiButtons.forEach((btn) => {
                    btn.classList.toggle("active", btn.dataset.reparto === repartoCode);
                });
            }

            repartiButtons.forEach((btn) => {
                btn.addEventListener("click", () => {
                    const repartoCode = btn.dataset.reparto || "";
                    setActiveButton(repartoCode);
                    renderPage(repartoCode);
                });
            });

            // Stato iniziale: solo KPI globali, nessun reparto selezionato
            setActiveButton("");
            renderPage("");
        })();
    </script>
{% endblock %}            const repartoCode = btn.dataset.reparto || "";