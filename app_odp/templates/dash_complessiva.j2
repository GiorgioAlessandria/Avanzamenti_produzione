{% extends "base.j2" %}

{% block title %}Dashboard complessiva{% endblock %}

{% block content %}
    <main class="container-fluid mt-4 mb-4">
        <div class="row g-4">
            <div class="col-12 col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <h3 class="mb-0">Selezione reparto</h3>
                    </div>
                    <div class="card-body">
                        {% if kpi_reparti %}
                            <div class="list-group" id="dash-complessiva-reparti-list">
                                {% for reparto in kpi_reparti %}
                                    <button type="button"
                                            class="list-group-item list-group-item-action js-select-reparto {% if loop.first %}active{% endif %}"
                                            data-reparto="{{ reparto.codice }}">
                                        <div class="d-flex justify-content-between align-items-center gap-2">
                                            <span class="fw-semibold">{{ reparto.descrizione }}</span>
                                            <span class="badge text-bg-light">{{ reparto.kpi.totali }} ordini</span>
                                        </div>
                                    </button>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="alert alert-secondary mb-0">
                                Nessun reparto disponibile nel tuo perimetro.
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-8">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <h3 class="mb-0">Cruscotto KPI ordini</h3>
                    </div>
                    <div class="card-body" id="dash-complessiva-dettaglio"></div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}

{% block extra_js %}
    {{ super() }}

    <script id="dash-complessiva-global-kpi" type="application/json">{{ kpi_globali|tojson }}</script>
    <script id="dash-complessiva-reparti-kpi" type="application/json">{{ kpi_reparti|tojson }}</script>

    <script>
        (() => {
            const globalEl = document.getElementById("dash-complessiva-global-kpi");
            const repartiEl = document.getElementById("dash-complessiva-reparti-kpi");
            const detail = document.getElementById("dash-complessiva-dettaglio");
            const repartiButtons = document.querySelectorAll(".js-select-reparto");

            let globalKpi = {};
            let repartiKpi = [];

            try {
                globalKpi = JSON.parse(globalEl?.textContent || "{}");
            } catch (_) {
                globalKpi = {};
            }

            try {
                repartiKpi = JSON.parse(repartiEl?.textContent || "[]");
            } catch (_) {
                repartiKpi = [];
            }

            function escapeHtml(value) {
                return String(value ?? "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/\"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function formatHours(value) {
                return `${Number(value || 0).toFixed(2)} h`;
            }

            function formatPercent(value) {
                return `${Number(value || 0).toFixed(2)}%`;
            }

            function cardKpi(title, value) {
                return `
                    <div class="col-6 col-xl-4">
                        <div class="card border-0 bg-light h-100">
                            <div class="card-body">
                                <div class="text-muted small">${escapeHtml(title)}</div>
                                <div class="fs-4 fw-semibold">${escapeHtml(value)}</div>
                            </div>
                        </div>
                    </div>
                `;
            }

            function renderKpiGrid(kpi) {
                return `
                    <div class="row g-3">
                        ${cardKpi("Ordini totali", kpi.totali || 0)}
                        ${cardKpi("Ordini pianificati", kpi.pianificati || 0)}
                        ${cardKpi("Ordini sospesi", kpi.sospesi || 0)}
                        ${cardKpi("Ordini attivi", kpi.attivi || 0)}
                        ${cardKpi("Ore lavorazione", formatHours(kpi.ore_lavorazione))}
                        ${cardKpi("Ore attrezzaggio", formatHours(kpi.ore_attrezzaggio))}
                        ${cardKpi("% ordini sospesi", formatPercent(kpi.percentuale_sospesi))}
                        ${cardKpi("% ordini attivi", formatPercent(kpi.percentuale_attivi))}
                    </div>
                `;
            }

            function renderPage(repartoCode) {
                const reparto = repartiKpi.find((item) => item.codice === repartoCode);
                const repartoLabel = reparto
                    ? `${reparto.descrizione} (${reparto.codice})`
                    : "Nessun reparto selezionato";

                detail.innerHTML = `
                    <div class="mb-4">
                        <h4 class="mb-3">KPI globali (sempre visibili)</h4>
                        ${renderKpiGrid(globalKpi)}
                    </div>

                    <div>
                        <h4 class="mb-3">KPI reparto selezionato: ${escapeHtml(repartoLabel)}</h4>
                        ${reparto ? renderKpiGrid(reparto.kpi || {}) : '<div class="alert alert-info mb-0">Seleziona un reparto per visualizzare i relativi KPI.</div>'}
                    </div>
                `;
            }

            function setActiveButton(repartoCode) {
                repartiButtons.forEach((btn) => {
                    btn.classList.toggle("active", btn.dataset.reparto === repartoCode);
                });
            }

            repartiButtons.forEach((btn) => {
                btn.addEventListener("click", () => {
                    const repartoCode = btn.dataset.reparto;
                    setActiveButton(repartoCode);
                    renderPage(repartoCode);
                });
            });

            if (repartiKpi.length > 0) {
                renderPage(repartiKpi[0].codice);
            } else {
                renderPage("");
            }
        })();
    </script>
{% endblock %}
