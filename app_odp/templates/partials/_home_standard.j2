{% set has_disegno_permission = policy and policy.can('controllo_codice_disegno') %}
{% set lavorazioni_richiesta_disegni = config.get('LAVORAZIONI_RICHIESTA_DISEGNI', []) %}
<!--toast nuovo ordine in carico -->
<div class="toast lh-lg hide"

     role="alert"
     id="toast-1"
     style="width: max-content;height: max-content;position: fixed; top: 1rem; right: 1rem; z-index: 2000;opacity: 1;filter: blur(0px);">
    <div class="toast-header">
        <strong class="me-auto"
                style="font-size: 25px;">Presa in carico dell'ordine
            <span data-bind-text="ordine"></span></strong>
        <button class="btn-close ms-2 mb-1 close"
                type="button"
                aria-label="Close"
                data-bs-dismiss="toast"
                style="font-size: 25px;"></button>
    </div>
    <div class="toast-body d-flex flex-column justify-content-center align-items-center"
         role="alert"
         style="opacity: 1;width: auto;height: auto;">
        <input type="hidden"
               data-bind="iddocumento"
               id="toast1-iddocumento">
        <input type="hidden"
               data-bind="idriga"
               id="toast1-idriga">
        <input type="hidden"
               data-bind="ordine"
               id="toast1-ordine">
        <input type="hidden"
               data-bind="codice"
               id="toast1-codice">
        <input type="hidden"
               data-bind="indicemodifica"
               id="toast1-indicemodifica">
        <input type="hidden"
               data-bind="quantita"
               id="toast1-quantita">
        <input type="hidden"
               data-bind="fase"
               id="toast1-fase">
        <input type="hidden"
               data-bind="lavorazione"
               id="toast1-lavorazione">
        <input type="hidden"
               data-bind="numprogrriga"
               id="toast1-numprogrriga">

        <div class="row"
             style="font-size: 20px;  border-radius: 4px;">
            <label class="form-check-label"
                   for="toast-ordine-mascherato">Ordine mascherato</label>
            <input class="form-check mt-1 mb-1"
                   type="checkbox"
                   id="toast-ordine-mascherato">
        </div>

        <div class="row mt-2 w-100"
             id="toast-ordine-mascherato-wrapper"
             style="display: none; font-size: 20px; background: #f8f9fa; border-radius: 4px; padding: 8px;">
            <label class="form-label mb-1"
                   for="toast-ordine-mascherato-select">
                Seleziona ordine principale attivo
            </label>

            <select id="toast-ordine-mascherato-select"
                    class="form-select">
                <option value="">-- Seleziona ordine attivo --</option>
            </select>

            <input type="hidden"
                   id="toast-ordine-mascherato-iddocumento-principale">
            <input type="hidden"
                   id="toast-ordine-mascherato-idriga-principale">
        </div>

        {% if has_disegno_permission %}
            <div class="mt-3 w-100"
                 id="toast1-scan-wrapper"
                 style="display: none;">
                <label for="toast1-scan-disegno"
                       class="form-label fw-semibold mb-1"
                       style="font-size: 20px;">
                    Scansione disegno (codice + revisione)
                </label>

                <textarea id="toast1-scan-disegno"
                          class="form-control"
                          rows="2"
                          spellcheck="false"
                          autocomplete="off"
                          autocapitalize="characters"
                          placeholder="Scansiona qui il codice a barre del disegno"></textarea>

                <div id="toast1-scan-feedback"
                     class="invalid-feedback"
                     style="font-size: 16px;">
                    Il disegno scansionato non corrisponde all'ordine selezionato.
                </div>
            </div>
        {% endif %}

        <button class="btn btn-primary mt-3"
                id="btn-prendi-ordine"
                type="button">
            Preso in carico
        </button>
    </div>
</div>
