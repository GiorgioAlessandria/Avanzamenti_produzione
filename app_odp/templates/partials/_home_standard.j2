    (() => {
        const toastEl = document.getElementById("toast-1");
        const scanWrapper = document.getElementById("toast1-scan-wrapper");
        const scanField = document.getElementById("toast1-scan-disegno");
        const feedbackEl = document.getElementById("toast1-scan-feedback");
        const lavorazioneField = document.getElementById("toast1-lavorazione");

        const hasDisegnoPermission = {{ (has_disegno_permission)|tojson }};
        const requiredLavorazioni = new Set(
            {{ lavorazioni_richiesta_disegni|tojson }}.map(v =>
                String(v ?? "").trim().toUpperCase()
            )
        );

        function normalizeValue(value) {
            return String(value ?? "")
                .trim()
                .toUpperCase()
                .replace(/\s+/g, "");
        }

        function normalizeCode(value) {
            return String(value ?? "")
                .trim()
                .toUpperCase()
                .replace(/\s+/g, "");
        }

        function normalizeRevision(rev) {
            const value = normalizeCode(rev);

            if (!value || value === "X" || value === "-") {
                return "";
            }

            return value;
        }

        function normalizeLavorazione(value) {
            return String(value ?? "")
                .trim()
                .toUpperCase();
        }

        function getCurrentLavorazione() {
            return normalizeLavorazione(lavorazioneField?.value || "");
        }

        function currentOrderRequiresDrawingScan() {
            if (!hasDisegnoPermission) return false;

            const lavorazione = getCurrentLavorazione();
            if (!lavorazione) return false;

            return requiredLavorazioni.has(lavorazione);
        }

        function getExpectedDrawingCode() {
            const codice = document.getElementById("toast1-codice")?.value || "";
            const indiceModifica = document.getElementById("toast1-indicemodifica")?.value || "";

            return normalizeCode(codice) + normalizeRevision(indiceModifica);
        }

        function setInvalid(message) {
            if (!scanField || !feedbackEl) return;
            scanField.classList.add("is-invalid");
            feedbackEl.textContent = message || "Il disegno scansionato non corrisponde all'ordine selezionato.";
        }

        function clearInvalid() {
            if (!scanField || !feedbackEl) return;
            scanField.classList.remove("is-invalid");
            feedbackEl.textContent = "Il disegno scansionato non corrisponde all'ordine selezionato.";
        }

        function resetScanField() {
            if (scanField) {
                scanField.value = "";
            }
            clearInvalid();
        }

        function syncScanUi() {
            const requiredForOrder = currentOrderRequiresDrawingScan();

            if (scanWrapper) {
                scanWrapper.style.display = requiredForOrder ? "" : "none";
            }

            if (scanField) {
                scanField.required = requiredForOrder;

                if (!requiredForOrder) {
                    scanField.value = "";
                    scanField.classList.remove("is-invalid");
                }
            }

            clearInvalid();
        }

        if (!toastEl || !lavorazioneField) {
            return;
        }

        window.validateDrawingScanToast1 = function () {
            const requiredForOrder = currentOrderRequiresDrawingScan();

            if (!requiredForOrder) {
                clearInvalid();
                return true;
            }

            const scanned = normalizeValue(scanField?.value || "");
            const expected = getExpectedDrawingCode();

            if (!scanned) {
                setInvalid("La scansione del disegno è obbligatoria.");
                scanField?.focus();
                return false;
            }

            if (!expected) {
                setInvalid("Impossibile validare il disegno: codice o revisione mancanti sull'ordine.");
                scanField?.focus();
                return false;
            }

            if (scanned !== expected) {
                setInvalid("Disegno errato: il codice scansionato non corrisponde all'ordine selezionato.");
                scanField?.focus();
                scanField?.select();
                return false;
            }

            clearInvalid();
            return true;
        };

        scanField?.addEventListener("input", clearInvalid);

        document.addEventListener("click", function (event) {
            const btn = event.target.closest('[data-bs-target="#toast-1"]');
            if (!btn) return;

            requestAnimationFrame(() => {
                resetScanField();
                syncScanUi();
            });
        });

        toastEl.addEventListener("hidden.bs.toast", () => {
            resetScanField();
            syncScanUi();
        });
    })();
</script>
<script>
    document.getElementById("btn-prendi-ordine")?.addEventListener("click", async function () {
        const btn = this;
        const idDocumento = document.getElementById("toast1-iddocumento")?.value?.trim() || "";
        const idRiga = document.getElementById("toast1-idriga")?.value?.trim() || "";
        const chkMascherato = document.getElementById("toast-ordine-mascherato");
        const selectMascherato = document.getElementById("toast-ordine-mascherato-select");
        const idDocumentoPrincipale = document.getElementById("toast-ordine-mascherato-iddocumento-principale")?.value?.trim() || "";
        const idRigaPrincipale = document.getElementById("toast-ordine-mascherato-idriga-principale")?.value?.trim() || "";
        const numProgrRiga =
            document.getElementById("toast-chiudi-sl-numprogrriga")?.value?.trim() || "";

        if (!window.validateDrawingScanToast1()) {
            return;
        }

        if (chkMascherato?.checked && (!idDocumentoPrincipale || !idRigaPrincipale || !selectMascherato?.value)) {
            alert("Seleziona l'ordine principale attivo da associare all'ordine mascherato.");
            return;
        }

        if (!idDocumento || !idRiga) {
            console.error("IdDocumento o IdRiga mancanti");
            return;
        }

        btn.disabled = true;

        try {
            const resp = await fetch("/api/ordini/presa", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "X-Requested-With": "XMLHttpRequest"
                },
                credentials: "same-origin",
                body: JSON.stringify({
                    id_documento: idDocumento,
                    id_riga: idRiga,
                    id_documento_principale: idDocumentoPrincipale,
                    id_riga_principale: idRigaPrincipale,
                    num_progr_riga: numProgrRiga
                })
            });

            let data = {};
            try {
                data = await resp.json();
            } catch (_) {
                data = {};
            }

            if (!resp.ok || data.ok === false) {
                console.error("Errore nella presa in carico:", data);
                alert(data.error || "Errore durante la presa in carico dell'ordine.");
                return;
            }

            const toastEl = document.getElementById("toast-1");
            bootstrap.Toast.getOrCreateInstance(toastEl).hide();

            if (data.fragments && window.applyHomeFragments) {
                window.applyHomeFragments(data.fragments);
            } else {
                const rowKey = data.row_key || `${idDocumento}|${idRiga}`;
                const selectedRow = document.querySelector(
                    `tr[data-row-key="${CSS.escape(rowKey)}"]`
                );
                if (selectedRow) {
                    selectedRow.remove();
                }
            }

            document.getElementById("sospensione_ordine")?.setAttribute("disabled", "disabled");
            document.getElementById("riattivazione_ordine")?.setAttribute("disabled", "disabled");

        } catch (err) {
            console.error("Errore fetch presa ordine:", err);
            alert("Errore di comunicazione con il server.");
        } finally {
            btn.disabled = false;
        }
    });
</script>
