<script>
    (() => {
        // ---- Stato lotti SL ----
        let _lottiData = [];
        let _hasLotti = false;
        let _hasSelectableLotti = false;
        let _rowCounter = 0;

        // ---- DOM ----
        const toastEl = document.getElementById("toast-4");
        const section = document.getElementById("lotti-section-sl");
        const loading = document.getElementById("lotti-loading-sl");
        const alertEl = document.getElementById("lotti-alert-sl");
        const tbody = document.getElementById("tbody-lotti-sl");
        const riepilogo = document.getElementById("lotti-riepilogo-sl");
        const hidQtyResidua = document.getElementById("toast-chiudi-sl-quantita");
        const hidQtyTotale = document.getElementById("toast-chiudi-sl-quantita-totale");
        const inpConf = document.getElementById("toast-chiudi-sl-quantita-conforme");
        const inpNonConf = document.getElementById("toast-chiudi-sl-quantita-non-conforme");
        const chkParziale = document.getElementById("toast-chiudi-sl-parziale");
        const chkTotale = document.getElementById("toast-chiudi-sl-totale");

        if (!toastEl || !section || !tbody) return;

        // ---- Utility ----
        function escHtml(s) {
            return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;")
                .replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
        }

        function showAlert(msg) {
            if (!alertEl) return;
            alertEl.textContent = msg;
            alertEl.style.display = msg ? "" : "none";
        }

        function isGestioneLottoSi(comp) {
            const flag = String(
                comp?.GestioneLotto
                ?? comp?.gestione_lotto
                ?? comp?.gestioneLotto
                ?? ""
            ).trim().toLowerCase();

            if (flag) {
                return flag === "si";
            }

            return Array.isArray(comp?.lotti) && comp.lotti.length > 0;
        }

        function parseIntQty(v) {
            let s = String(v ?? "").trim().replace(/\s+/g, "");
            if (!s) return NaN;

            if (s.includes(",") || s.includes(".")) {
                return NaN;
            }

            if (!/^\d+$/.test(s)) {
                return NaN;
            }

            const n = Number(s);
            return Number.isSafeInteger(n) ? n : NaN;
        }

        function parseQtyOrZero(v) {
            const n = parseIntQty(v);
            return Number.isFinite(n) ? n : 0;
        }

        function parseSystemQty(v) {
            let s = String(v ?? "").trim().replace(/\s+/g, "");
            if (!s) return NaN;

            if (s.includes(",") && s.includes(".")) {
                s = s.replace(/\./g, "");
            }

            s = s.replace(",", ".");
            const n = Number(s);
            return Number.isFinite(n) ? n : NaN;
        }

        function sanitizeIntegerInput(el) {
            if (!el) return;

            el.setAttribute("inputmode", "numeric");
            el.setAttribute("step", "1");
            el.setAttribute("min", "0");
            el.setAttribute("pattern", "\\d*");

            el.addEventListener("input", () => {
                const cleaned = String(el.value ?? "").replace(/[^\d]/g, "");
                if (el.value !== cleaned) {
                    el.value = cleaned;
                }
            });

            el.addEventListener("blur", () => {
                const raw = String(el.value ?? "").trim();
                if (!raw) {
                    el.value = "0";
                    return;
                }
                const n = parseIntQty(raw);
                el.value = Number.isFinite(n) ? String(n) : "0";
            });
        }

        function sameQty(a, b) {
            return Math.abs(Number(a || 0) - Number(b || 0)) < 0.000001;
        }

        function getQuantitaResiduaCorrente() {
            const n = parseSystemQty(hidQtyResidua?.value);
            return Number.isFinite(n) ? n : 0;
        }

        function getQuantitaTotaleOrdine() {
            const n = parseSystemQty(hidQtyTotale?.value);
            return Number.isFinite(n) ? n : 0;
        }

        function getQuantitaLavorataCorrente() {
            const qConf = parseQtyOrZero(inpConf?.value);
            const qNonConf = parseQtyOrZero(inpNonConf?.value);
            return qConf + qNonConf;
        }

        function getQuantitaRichiestaComponente(comp) {
            const baseQty = parseSystemQty(comp?.Quantita);
            const qOrdTotale = getQuantitaTotaleOrdine();
            const qLavorata = getQuantitaLavorataCorrente();

            if (!Number.isFinite(baseQty) || baseQty <= 0) return 0;
            if (!Number.isFinite(qLavorata) || qLavorata <= 0) return 0;

            if (!Number.isFinite(qOrdTotale) || qOrdTotale <= 0) {
                return Math.round(baseQty);
            }

            const richiesto = (baseQty * qLavorata) / qOrdTotale;

            if (!Number.isFinite(richiesto)) return 0;

            return Math.round(richiesto);
        }

        function resetQuantitaInputs() {
            const qResidua = getQuantitaResiduaCorrente();

            if (Number.isFinite(qResidua) && qResidua > 0) {
                inpConf.value = String(Math.round(qResidua));
            } else {
                inpConf.value = "";
            }

            inpNonConf.value = "0";
            if (chkParziale) chkParziale.checked = false;
            if (chkTotale) chkTotale.checked = false;

            const noteEl = document.getElementById("toast-chiudi-sl-note");
            if (noteEl) noteEl.value = "";
        }

        // ---- Dropdown lotti ----
        function buildLottoSelect(lotti, selectedLotto = "") {
            let html = '<select class="form-select form-select-sm lotto-select-sl">';
            html += '<option value="">-- Seleziona lotto --</option>';
            for (const l of (lotti || [])) {
                const value = String(l.RifLottoAlfa || "");
                const giacenza = parseSystemQty(l.Giacenza);
                const codMag = String(l.CodMag || "");
                const sel = value === selectedLotto ? " selected" : "";
                html += `
            <option value="${escHtml(value)}"
                    data-giacenza="${Number.isFinite(giacenza) ? giacenza : 0}"
                    data-codmag="${escHtml(codMag)}"${sel}>
                ${escHtml(value)} (mag: ${escHtml(codMag || "-")})
            </option>`;
            }
            html += "</select>";
            return html;
        }

        // ---- Crea riga lotto ----
        function addLottoRow(codArt, desArt, lotti, isInitial) {
            _rowCounter++;
            const tr = document.createElement("tr");
            tr.id = `lotto-sl-row-${_rowCounter}`;
            tr.dataset.codart = codArt;

            tr.innerHTML = `
            <td class="fw-semibold" style="font-size: 20px;">${escHtml(codArt)}</td>
            <td style="font-size: 20px;">${escHtml(desArt)}</td>
            <td>${buildLottoSelect(lotti)}</td>
            <td class="text-end giacenza-cell-sl" style="font-size: 20px;">-</td>
            <td>
                <input type="number" class="form-control form-control-sm lotto-qty-sl text-end"
                       min="0" step="1" value="" placeholder="0" style="width: 90px;">
            </td>
            <td>
                <select class="form-select form-select-sm lotto-esito-sl" style="width: 70px;">
                    <option value="ok">OK</option>
                    <option value="ko">KO</option>
                </select>
            </td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-outline-primary btn-add-lotto-sl me-1"
                        title="Aggiungi riga" data-codart="${escHtml(codArt)}"
                        data-desart="${escHtml(desArt)}">+</button>
                ${isInitial ? "" : '<button type="button" class="btn btn-sm btn-outline-danger btn-rem-lotto-sl" title="Rimuovi">−</button>'}
            </td>
        `;
            tbody.appendChild(tr);
            sanitizeIntegerInput(tr.querySelector(".lotto-qty-sl"));
            return tr;
        }

        sanitizeIntegerInput(inpConf);
        sanitizeIntegerInput(inpNonConf);

        [inpConf, inpNonConf].forEach(el => {
            el?.addEventListener("input", () => {
                if (_hasLotti) updateRiepilogo();
            });
        });

        chkParziale?.addEventListener("change", () => {
            if (chkParziale.checked && chkTotale) {
                chkTotale.checked = false;
            }
            if (_hasLotti) updateRiepilogo();
        });

        chkTotale?.addEventListener("change", () => {
            if (chkTotale.checked && chkParziale) {
                chkParziale.checked = false;
            }
            if (_hasLotti) updateRiepilogo();
        });

        // ---- Aggiorna giacenza al cambio lotto ----
        tbody.addEventListener("change", function (e) {
            const sel = e.target.closest(".lotto-select-sl");
            if (sel) {
                const row = sel.closest("tr");
                const giacCell = row.querySelector(".giacenza-cell-sl");
                const qtyInput = row.querySelector(".lotto-qty-sl");
                const opt = sel.options[sel.selectedIndex];

                if (opt && opt.value) {
                    const g = parseSystemQty(opt.dataset.giacenza);
                    giacCell.textContent = Number.isFinite(g) ? g : 0;
                    qtyInput.max = Number.isFinite(g) ? String(g) : "";
                } else {
                    giacCell.textContent = "-";
                    qtyInput.max = "";
                }
            }

            if (
                e.target.closest(".lotto-select-sl") ||
                e.target.closest(".lotto-esito-sl")
            ) {
                updateRiepilogo();
                validateLotti();
            }
        });

        tbody.addEventListener("input", function (e) {
            if (e.target.classList.contains("lotto-qty-sl")) {
                updateRiepilogo();
                validateLotti();
            }
        });

        tbody.addEventListener("input", function (e) {
            if (e.target.classList.contains("lotto-qty-sl")) updateRiepilogo();
        });

        // ---- +/- righe ----
        tbody.addEventListener("click", function (e) {
            const btnAdd = e.target.closest(".btn-add-lotto-sl");
            if (btnAdd) {
                const codArt = btnAdd.dataset.codart;
                const desArt = btnAdd.dataset.desart;
                const comp = _lottiData.find(c => c.CodArt === codArt);
                if (comp) addLottoRow(codArt, desArt, comp.lotti, false);
                updateRiepilogo();
                return;
            }
            const btnRem = e.target.closest(".btn-rem-lotto-sl");
            if (btnRem) {
                btnRem.closest("tr")?.remove();
                updateRiepilogo();
            }
        });

        // ---- Riepilogo ----
        function updateRiepilogo() {
            if (!riepilogo) return;

            const totals = {};
            tbody.querySelectorAll("tr").forEach(row => {
                const cod = row.dataset.codart || "";
                const qty = parseQtyOrZero(row.querySelector(".lotto-qty-sl")?.value);
                const esito = row.querySelector(".lotto-esito-sl")?.value || "ok";

                if (!totals[cod]) totals[cod] = {ok: 0, ko: 0, totale: 0};
                if (esito === "ok") totals[cod].ok += qty;
                else totals[cod].ko += qty;
                totals[cod].totale += qty;
            });

            let html = "<strong>Riepilogo per componente:</strong><br>";
            for (const comp of _lottiData) {
                const codArt = String(comp.CodArt || "");
                const richiesto = getQuantitaRichiestaComponente(comp);
                const t = totals[codArt] || {ok: 0, ko: 0, totale: 0};
                const ok = sameQty(t.totale, richiesto);

                html += `
            <span class="${ok ? "text-success" : "text-danger"}">
                ${escHtml(codArt)}: ${t.totale}/${richiesto}
                (OK: ${t.ok}, KO: ${t.ko})${ok ? " ✓" : " ✗"}
            </span><br>`;
            }

            riepilogo.innerHTML = html;
        }

        // ---- Carica lotti dal server ----
        async function fetchLottiData(idDocumento, idRiga) {
            section.style.display = "none";
            loading.style.display = "";
            tbody.innerHTML = "";
            showAlert("");
            riepilogo.innerHTML = "";
            _lottiData = [];
            _hasLotti = false;
            _hasSelectableLotti = false;

            try {
                const resp = await fetch("/api/ordini/lotti-componenti", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    credentials: "same-origin",
                    body: JSON.stringify({
                        id_documento: idDocumento,
                        id_riga: idRiga,
                        modalita: "sl",
                        num_progr_riga: numProgrRiga
                    })
                });

                const data = await resp.json();

                if (!resp.ok || !data.ok) {
                    showAlert(data.error || "Errore nel caricamento dei lotti.");
                    return;
                }

                const forceShow = !!data.force_show_section;
                const rawComponenti = Array.isArray(data.componenti) ? data.componenti : [];

                _lottiData = rawComponenti.filter(comp => isGestioneLottoSi(comp));

                const componentiConLotti = _lottiData.filter(
                    comp => Array.isArray(comp.lotti) && comp.lotti.length > 0
                );
                const componentiSenzaLotti = _lottiData.filter(
                    comp => !Array.isArray(comp.lotti) || comp.lotti.length === 0
                );

                _hasLotti = _lottiData.length > 0;
                _hasSelectableLotti = componentiConLotti.length > 0;

                if (!_hasLotti && !forceShow) {
                    section.style.display = "none";
                    return;
                }

                section.style.display = "";

                for (const comp of componentiConLotti) {
                    addLottoRow(comp.CodArt, comp.DesArt, comp.lotti, true);
                }

                if (componentiSenzaLotti.length > 0) {
                    const elenco = componentiSenzaLotti
                        .map(comp => `- ${comp.CodArt}${comp.DesArt ? ` (${comp.DesArt})` : ""}`)
                        .join("\n");

                    showAlert(
                        `Nessun lotto disponibile per i seguenti componenti della fase attiva:\n${elenco}`
                    );
                } else if (componentiConLotti.length === 0 && forceShow) {
                    showAlert("Nessun lotto disponibile per i componenti della fase attiva con GestioneLotto = si.");
                } else {
                    showAlert("");
                }

                updateRiepilogo();
            } catch (err) {
                console.error("Errore fetch lotti SL:", err);
                showAlert("Errore di comunicazione.");
            } finally {
                loading.style.display = "none";
            }
        }

        // ---- Validazione lotti ----
        function validateLotti() {
            if (!_hasLotti) return {valid: true, lottiPayload: []};

            const errors = [];
            const perCodice = {};
            const lottiPayload = [];

            // Raggruppamento per CodArt + Lotto
            const perLotto = {};

            tbody.querySelectorAll("tr").forEach(row => {
                const cod = row.dataset.codart || "";
                const lottoVal = row.querySelector(".lotto-select-sl")?.value || "";
                const giacenza = parseQtyOrZero(row.querySelector(".giacenza-cell-sl")?.textContent);
                const esito = row.querySelector(".lotto-esito-sl")?.value || "ok";
                const qtyRaw = row.querySelector(".lotto-qty-sl")?.value;
                const qty = parseIntQty(qtyRaw);

                if (!Number.isInteger(qty) || qty <= 0) {
                    errors.push(`${cod} lotto ${lottoVal}: inserire una quantità intera > 0.`);
                    return;
                }

                if (qty > 0 && !lottoVal) {
                    errors.push(`${cod}: selezionare un lotto.`);
                    return;
                }

                if (!lottoVal) return;

                if (qty <= 0) {
                    errors.push(`${cod} lotto ${lottoVal}: inserire qtà > 0.`);
                }

                if (qty > giacenza) {
                    errors.push(`${cod} lotto ${lottoVal}: qtà ${qty} > giacenza ${giacenza}.`);
                }

                const lottoSelect = row.querySelector(".lotto-select-sl");
                const selectedOption = lottoSelect?.options?.[lottoSelect.selectedIndex];
                const codMag = selectedOption?.dataset?.codmag || "";
                const lottoKey = `${cod}|${lottoVal}|${codMag}`;
                if (!perLotto[lottoKey]) {
                    perLotto[lottoKey] = {
                        cod,
                        lottoVal,
                        giacenza,
                        totale: 0,
                        ok: 0,
                        ko: 0,
                        righe: 0
                    };
                }

                perLotto[lottoKey].totale += qty;
                perLotto[lottoKey].righe += 1;
                if (esito === "ok") {
                    perLotto[lottoKey].ok += qty;
                } else {
                    perLotto[lottoKey].ko += qty;
                }

                if (!perCodice[cod]) perCodice[cod] = {ok: 0, ko: 0, totale: 0};
                if (esito === "ok") perCodice[cod].ok += qty;
                else perCodice[cod].ko += qty;
                perCodice[cod].totale += qty;

                lottiPayload.push({
                    CodArt: cod,
                    RifLottoAlfa: lottoVal,
                    CodMag: codMag,
                    Quantita: qty,
                    Esito: esito
                });
            });

            // Regole duplicati stesso lotto
            for (const key of Object.keys(perLotto)) {
                const info = perLotto[key];

                if (info.righe <= 1) continue;

                // Se tutte le righe del lotto sono OK, il duplicato non è ammesso
                if (info.ko === 0) {
                    errors.push(
                        `${info.cod}: lotto ${info.lottoVal} duplicato non consentito su più righe OK.`
                    );
                    continue;
                }

                // Se esiste almeno una KO, il duplicato è ammesso solo entro la giacenza
                if (info.totale > info.giacenza) {
                    errors.push(
                        `${info.cod}: lotto ${info.lottoVal} duplicato con KO ma somma quantità ${info.totale} > giacenza ${info.giacenza}.`
                    );
                }
            }

            // Controllo totale per componente
            for (const comp of _lottiData) {
                const codArt = String(comp.CodArt || "");
                const richiesto = getQuantitaRichiestaComponente(comp);
                const totale = perCodice[codArt]?.totale || 0;

                if (!sameQty(totale, richiesto)) {
                    errors.push(`${codArt}: somma lotti (${totale}) ≠ richiesta (${richiesto}).`);
                }
            }

            if (errors.length > 0) {
                showAlert(errors.join("\n"));
                return {valid: false, lottiPayload: []};
            }

            showAlert("");
            return {valid: true, lottiPayload};
        }

        // ---- Apertura toast: autofill + carica lotti ----
        document.addEventListener("click", function (e) {
            const btn = e.target.closest('[data-bs-target="#toast-4"]');
            if (!btn) return;

            requestAnimationFrame(() => {
                resetQuantitaInputs();

                const idDoc = document.getElementById("toast-chiudi-sl-iddocumento")?.value?.trim() || "";
                const idRiga = document.getElementById("toast-chiudi-sl-idriga")?.value?.trim() || "";

                if (idDoc && idRiga) {
                    fetchLottiData(idDoc, idRiga);
                } else {
                    section.style.display = "none";
                }
            });
        });

        // ---- Conferma chiusura SL ----
        document.getElementById("btn-conferma-chiusura-sl")?.addEventListener("click", async function (event) {
            event.preventDefault();

            const btn = this;
            const idDocumento = document.getElementById("toast-chiudi-sl-iddocumento")?.value?.trim() || "";
            const idRiga = document.getElementById("toast-chiudi-sl-idriga")?.value?.trim() || "";
            const qOrd = document.getElementById("toast-chiudi-sl-quantita")?.value?.trim() || "";
            const qConf = document.getElementById("toast-chiudi-sl-quantita-conforme")?.value?.trim() || "";
            const qNonConf = document.getElementById("toast-chiudi-sl-quantita-non-conforme")?.value?.trim() || "";
            const note = document.getElementById("toast-chiudi-sl-note")?.value?.trim() || "";
            const chiusuraParziale = document.getElementById("toast-chiudi-sl-parziale")?.checked === true;
            const chiusuraTotale = document.getElementById("toast-chiudi-sl-totale")?.checked === true;
            const tempoNonFunzionamentoMinuti =
                document.getElementById("toast-chiudi-sl-tempo-fermo-macchina")?.value?.trim() || "0";

            if (chiusuraParziale === chiusuraTotale) {
                alert("Selezionare una sola modalità di chiusura: parziale oppure totale.");
                return;
            }
            if (!idDocumento || !idRiga) {
                alert("Ordine non valido (IdDocumento/IdRiga mancanti).");
                return;
            }

            // Validazione quantità
            const nConf = parseIntQty(qConf);
            const nNonConf = parseIntQty(qNonConf);

            const qOrdResiduaRaw = document.getElementById("toast-chiudi-sl-quantita")?.value?.trim() || "";
            const nOrdResiduaRaw = parseSystemQty(qOrdResiduaRaw);
            const nOrdResidua = Number.isFinite(nOrdResiduaRaw) ? Math.round(nOrdResiduaRaw) : NaN;
            const numProgrRiga =
                document.getElementById("toast-chiudi-sl-numprogrriga")?.value?.trim() || "";
            if (!Number.isInteger(nConf) || nConf < 0) {
                alert("Quantità conforme non valida: inserire un numero intero >= 0.");
                return;
            }
            if (!Number.isInteger(nNonConf) || nNonConf < 0) {
                alert("Quantità KO non valida: inserire un numero intero >= 0.");
                return;
            }

            if (!Number.isFinite(nConf) || nConf < 0) {
                alert("Quantità conforme non valida.");
                return;
            }
            if (!Number.isFinite(nNonConf) || nNonConf < 0) {
                alert("Quantità KO non valida.");
                return;
            }

            const nLavorata = nConf + nNonConf;
            if (nLavorata <= 0) {
                alert("Devi indicare una quantità lavorata > 0.");
                return;
            }

            if (chiusuraParziale) {
                if (!Number.isFinite(nOrdResidua) || nOrdResidua <= 0) {
                    alert("Quantità residua ordine non valida.");
                    return;
                }

                if (nLavorata >= nOrdResidua) {
                    alert("Nella chiusura parziale la quantità lavorata deve essere strettamente minore della quantità residua dell'ordine.");
                    return;
                }
            }

            // Validazione lotti
            let lottiPayload = [];
            if (_hasLotti) {
                if (!_hasSelectableLotti) {
                    alert("Impossibile chiudere l'ordine: mancano i lotti necessari per i componenti obbligatori.");
                    return;
                }

                const validation = validateLotti();
                if (!validation.valid) return;
                lottiPayload = validation.lottiPayload;

                const totKoLotti = lottiPayload
                    .filter(l => l.Esito === "ko")
                    .reduce((s, l) => s + l.Quantita, 0);

                if (nNonConf === 0 && totKoLotti > 0) {
                    alert("Hai lotti marcati KO ma quantità non conforme = 0. Correggere prima di procedere.");
                    return;
                }
                if (nNonConf > 0 && totKoLotti === 0) {
                    alert("Quantità non conforme > 0 ma nessun lotto è marcato KO. Correggere prima di procedere.");
                    return;
                }
            }

            btn.disabled = true;

            try {
                const resp = await fetch("/api/ordini/chiudi", {
                    method: "POST",
                    headers: {"Content-Type": "application/json", "X-Requested-With": "XMLHttpRequest"},
                    credentials: "same-origin",
                    body: JSON.stringify({
                        id_documento: idDocumento,
                        id_riga: idRiga,
                        quantita_conforme: String(nConf),
                        quantita_non_conforme: String(nNonConf),
                        note: note,
                        lotti: lottiPayload,
                        chiusura_parziale: chiusuraParziale,
                        tempo_non_funzionamento_minuti: tempoNonFunzionamentoMinuti,
                        num_progr_riga: numProgrRiga
                    })
                });

                let data = {};
                try {
                    data = await resp.json();
                } catch (_) {
                    data = {};
                }

                if (!resp.ok || data.ok === false) {
                    console.error("Errore chiusura SL:", data);
                    alert(data.error || "Errore durante la chiusura dell'ordine.");
                    return;
                }

                const exportResult = await exportAvpTxt({
                    suffix: "officina",
                    outboxId: data.outbox_id
                });
                if (!exportResult.ok) {
                    alert(exportResult.error || "Ordine chiuso, ma file ERP non generato.");
                }

                bootstrap.Toast.getOrCreateInstance(toastEl).hide();

                if (data.fragments && window.applyHomeFragments) {
                    window.applyHomeFragments(data.fragments);
                }

                // Reset
                const btnSosp = document.getElementById("sospensione_ordine");
                const btnRiatt = document.getElementById("riattivazione_ordine");
                if (btnSosp) btnSosp.disabled = true;
                if (btnRiatt) btnRiatt.disabled = true;
                section.style.display = "none";
                tbody.innerHTML = "";
                _lottiData = [];
                _hasLotti = false;
                _hasSelectableLotti = false;

            } catch (err) {
                console.error("Errore fetch chiusura SL:", err);
                alert("Errore di comunicazione con il server.");
            } finally {
                btn.disabled = false;
            }
        });
    })();
</script>
<script>
    async function exportAvpTxt({suffix = "officina", outboxId} = {}) {
        if (!outboxId) {
            return {
                ok: false,
                error: "outbox_id mancante per la generazione del file ERP."
            };
        }

        try {
            const resp = await fetch("/api/erp/export/avp", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "X-Requested-With": "XMLHttpRequest"
                },
                credentials: "same-origin",
                body: JSON.stringify({
                    suffix,
                    outbox_id: outboxId
                })
            });

            let data = {};
            try {
                data = await resp.json();
            } catch (_) {
                data = {};
            }

            if (!resp.ok || data.ok === false) {
                return {
                    ok: false,
                    error: data.error || "Errore durante la generazione del file ERP."
                };
            }

            return {ok: true, data};
        } catch (err) {
            console.error("Errore export AVP:", err);
            return {
                ok: false,
                error: "Errore di comunicazione durante la generazione del file ERP."
            };
        }
    }
</script>
<script>
    (() => {
        const chkMascherato = document.getElementById("toast-ordine-mascherato");
        const wrapperMascherato = document.getElementById("toast-ordine-mascherato-wrapper");
        const selectMascherato = document.getElementById("toast-ordine-mascherato-select");
        const hidIdDocPrincipale = document.getElementById("toast-ordine-mascherato-iddocumento-principale");
        const hidIdRigaPrincipale = document.getElementById("toast-ordine-mascherato-idriga-principale");
        const toastEl = document.getElementById("toast-1");

        if (!chkMascherato || !wrapperMascherato || !selectMascherato || !toastEl) return;

        function resetOrdineMascheratoUi() {
            chkMascherato.checked = false;
            wrapperMascherato.style.display = "none";
            selectMascherato.innerHTML = '<option value="">-- Seleziona ordine attivo --</option>';
            selectMascherato.disabled = false;
            hidIdDocPrincipale.value = "";
            hidIdRigaPrincipale.value = "";
        }

        function getRowValue(row, key, fallbackCol = "") {
            const dsValue = row?.dataset?.[key];
            if (typeof dsValue === "string" && dsValue.trim()) {
                return dsValue.trim();
            }

            if (fallbackCol) {
                const cell = row.querySelector(`td[data-col="${fallbackCol}"]`);
                if (cell?.textContent?.trim()) {
                    return cell.textContent.trim();
                }
            }

            return "";
        }

        function collectOrdiniAttivi() {
            const rows = document.querySelectorAll("#ordini_in_corso tbody tr[data-row-key]");
            const result = [];

            rows.forEach((row) => {
                const stato = getStatoOrdine(row);
                if (stato !== "Attivo") return;

                const rowKey = row.dataset.rowKey || "";
                const [idDocumentoFromKey = "", idRigaFromKey = ""] = rowKey.split("|");

                const idDocumento = getRowValue(row, "iddocumento") || idDocumentoFromKey;
                const idRiga = getRowValue(row, "idriga") || idRigaFromKey;
                const ordine = getRowValue(row, "ordine", "ordine");
                const codice = getRowValue(row, "codice", "codice");
                const descrizione = getRowValue(row, "descrizione", "descrizione");

                if (!idDocumento || !idRiga || !ordine) return;

                result.push({
                    idDocumento,
                    idRiga,
                    ordine,
                    codice,
                    descrizione
                });
            });

            return result;
        }

        function popolaSelectOrdiniAttivi() {
            const ordiniAttivi = collectOrdiniAttivi();

            selectMascherato.innerHTML = "";

            const placeholder = document.createElement("option");
            placeholder.value = "";
            placeholder.textContent = ordiniAttivi.length
                ? "-- Seleziona ordine attivo --"
                : "Nessun ordine attivo disponibile";
            selectMascherato.appendChild(placeholder);

            ordiniAttivi.forEach((ordine) => {
                const opt = document.createElement("option");
                opt.value = `${ordine.idDocumento}|${ordine.idRiga}`;
                opt.dataset.iddocumento = ordine.idDocumento;
                opt.dataset.idriga = ordine.idRiga;

                const parts = [ordine.ordine];
                if (ordine.codice) parts.push(ordine.codice);
                if (ordine.descrizione) parts.push(ordine.descrizione);

                opt.textContent = parts.join(" - ");
                selectMascherato.appendChild(opt);
            });

            selectMascherato.disabled = ordiniAttivi.length === 0;
            hidIdDocPrincipale.value = "";
            hidIdRigaPrincipale.value = "";
        }

        chkMascherato.addEventListener("change", function () {
            if (this.checked) {
                wrapperMascherato.style.display = "";
                popolaSelectOrdiniAttivi();
                return;
            }

            wrapperMascherato.style.display = "none";
            selectMascherato.value = "";
            hidIdDocPrincipale.value = "";
            hidIdRigaPrincipale.value = "";
        });

        selectMascherato.addEventListener("change", function () {
            const selected = this.options[this.selectedIndex];

            hidIdDocPrincipale.value = selected?.dataset?.iddocumento || "";
            hidIdRigaPrincipale.value = selected?.dataset?.idriga || "";
        });

        document.addEventListener("click", function (event) {
            const btn = event.target.closest('[data-bs-target="#toast-1"]');
            if (!btn) return;

            requestAnimationFrame(() => {
                resetOrdineMascheratoUi();
            });
        });

        toastEl.addEventListener("hidden.bs.toast", resetOrdineMascheratoUi);
    })();
</script>