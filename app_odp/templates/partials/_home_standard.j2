<script>
    function getStatoOrdine(source) {
        if (!source) return "";

        if (source.dataset?.statoordine) {
            return source.dataset.statoordine.trim();
        }

        const withState = source.closest?.("[data-statoordine]");
        if (withState?.dataset?.statoordine) {
            return withState.dataset.statoordine.trim();
        }

        const row = source.closest?.("tr");
        if (row) {
            if (row.dataset?.statoordine) {
                return row.dataset.statoordine.trim();
            }

            const innerWithState = row.querySelector("[data-statoordine]");
            if (innerWithState?.dataset?.statoordine) {
                return innerWithState.dataset.statoordine.trim();
            }

            const statoCell = row.querySelector('td[data-col="stato"]');
            if (statoCell) {
                return statoCell.textContent.trim();
            }
        }

        return "";
    }

    function aggiornaBottoniOrdine(source) {
        const btnSospensione = document.getElementById("sospensione_ordine");
        const btnRiattivazione = document.getElementById("riattivazione_ordine");

        if (!btnSospensione || !btnRiattivazione) return;

        const stato = getStatoOrdine(source);

        if (stato === "Attivo") {
            btnSospensione.disabled = false;
            btnRiattivazione.disabled = true;
            return;
        }

        if (stato === "In Sospeso") {
            btnSospensione.disabled = true;
            btnRiattivazione.disabled = false;
            return;
        }

        btnSospensione.disabled = true;
        btnRiattivazione.disabled = true;
    }

    document.addEventListener("click", function (event) {
        const row = event.target.closest("tr[data-row-key]");
        if (!row) return;

        aggiornaBottoniOrdine(event.target);
    });

</script>
