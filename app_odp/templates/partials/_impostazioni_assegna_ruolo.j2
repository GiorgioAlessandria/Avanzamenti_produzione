<div class="row g-4 mb-4">
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="mb-0">Selezione utente</h3>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label for="select-user-role-assignment"
                           class="form-label fw-semibold">
                        Utente
                    </label>

                    <select id="select-user-role-assignment"
                            class="form-select">
                        <option value="">-- Seleziona un utente --</option>
                    </select>
                </div>

                <div class="text-muted small"
                     id="assign-role-users-count"></div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="mb-0">Dettaglio assegnazione</h3>
            </div>

            <div class="card-body">
                <div id="assign-role-feedback"
                     class="mb-3"></div>

                <div id="assign-role-detail">
                    <div class="alert alert-info mb-0">
                        Seleziona un utente per assegnare o sostituire il ruolo.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>