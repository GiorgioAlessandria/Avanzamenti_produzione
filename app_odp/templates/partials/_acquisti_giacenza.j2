<div class="card shadow-sm h-100 d-flex flex-column">
    <div class="card-header d-flex justify-content-between align-items-center flex-shrink-0">
        <h2 class="h4 mb-0">Giacenza complessiva</h2>
        <span class="text-muted small">
            Disponibilità per articolo
        </span>
    </div>

    <div class="card-body py-2 d-flex flex-column flex-grow-1 overflow-hidden">
        <div class="table-responsive flex-grow-1"
             style="overflow: auto;">
            <table class="table table-striped table-hover table-sortable table-sticky-wrap align-middle mb-0"
                   id="acquisti_giacenza_table">
                <thead>
                <tr>
                    <th data-sort="text">CodArt</th>
                    <th data-sort="text">Descrizione</th>
                    <th data-sort="text">UdM</th>
                    <th data-sort="num">Mag 0</th>
                    <th data-sort="num">Mag 10</th>
                    <th data-sort="num">Mag 13</th>
                    <th data-sort="num">Punto riordino</th>
                    <th data-sort="num">Lotto riordino</th>
                    <th data-sort="num">Lead time</th>
                    <th data-sort="date">Data prevista approvvigionamento</th>
                </tr>
                </thead>

                <tbody id="tbody_acquisti_giacenza">
                {% include "partials/_acquisti_giacenza_rows.j2" %}
                </tbody>
            </table>
        </div>
    </div>
</div>