<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="h4 mb-0">Giacenza complessiva</h2>
        <span class="text-muted small">
            Disponibilità per articolo
        </span>
    </div>

    <div class="card-body">
        <div class="table-responsive"
             style="max-height: 60vh; overflow: auto;">
            <table class="table table-striped table-hover table-sortable table-sticky-wrap align-middle"
                   id="acquisti_giacenza_table">
                <thead>
                <tr>
                    <th data-sort="text">CodArt</th>
                    <th data-sort="text">Descrizione</th>
                    <th data-sort="num">Mag 0</th>
                    <th data-sort="num">Mag 10</th>
                    <th data-sort="num">Mag 13</th>
                    <th data-sort="num">Punto riordino</th>
                    <th data-sort="num">Lotto riordino</th>
                    <th data-sort="num">Lead time</th>
                    <th data-sort="date">Data prevista approvvigionamento</th>
                </tr>
                </thead>

                <tbody id="tbody_acquisti_giacenza">
                {% if giacenze_rows %}
                    {% for row in giacenze_rows %}
                        <tr data-codart="{{ row.CodArt or '' }}"
                            data-desart="{{ row.DesArt or '' }}"
                            data-negative="{{ '1' if row.is_negative_any else '0' }}">
                            <td>{{ row.CodArt or '' }}</td>
                            <td>{{ row.DesArt or '' }}</td>

                            <td class="{% if row.Mag_0 < 0 %}text-danger fw-bold{% endif %}">
                                {{ row.Mag_0 }}
                            </td>

                            <td class="{% if row.Mag_10 < 0 %}text-danger fw-bold{% endif %}">
                                {{ row.Mag_10 }}
                            </td>

                            <td class="{% if row.Mag_13 < 0 %}text-danger fw-bold{% endif %}">
                                {{ row.Mag_13 }}
                            </td>

                            <td>{{ row.PuntoRiordino }}</td>
                            <td>{{ row.LottoRiordino }}</td>
                            <td>{{ row.PianTempoApprovFisso }}</td>
                            <td>{{ row.DataPrevistaApprovvigionamento or '' }}</td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="9"
                            class="text-center text-muted py-4">
                            Nessuna giacenza disponibile.
                        </td>
                    </tr>
                {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>