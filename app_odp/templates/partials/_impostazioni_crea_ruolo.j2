<div class="row g-4 mb-4">
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="mb-0">Creazione ruolo</h3>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label for="create-role-name"
                           class="form-label fw-semibold">
                        Nome ruolo
                    </label>
                    <input type="text"
                           id="create-role-name"
                           class="form-control"
                           maxlength="100"
                           placeholder="Es. responsabile_officina">
                </div>

                <div class="mb-4">
                    <label for="create-role-description"
                           class="form-label fw-semibold">
                        Descrizione
                    </label>
                    <input type="text"
                           id="create-role-description"
                           class="form-control"
                           maxlength="255"
                           placeholder="Es. Responsabile officina">
                </div>

                <div class="mb-4">
                    <label for="select-create-role-table"
                           class="form-label fw-semibold">
                        Tabella da configurare
                    </label>

                    <select id="select-create-role-table"
                            class="form-select">
                        <option value="">-- Seleziona una tabella --</option>
                        {% for item in role_creation_tables %}
                            <option value="{{ item.key }}">
                                {{ item.label }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="d-grid gap-2">
                    <button type="button"
                            class="btn btn-primary"
                            id="btn-create-role-save">
                        Crea ruolo
                    </button>

                    <button type="button"
                            class="btn btn-secondary"
                            id="btn-create-role-reset">
                        Annulla
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="mb-0">Configurazione connessioni iniziali</h3>
            </div>

            <div class="card-body">
                <div id="create-role-feedback"
                     class="mb-3"></div>

                <div id="create-role-detail">
                    <div class="alert alert-info mb-0">
                        Inserisci nome, descrizione e seleziona una tabella per configurare il nuovo ruolo.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>