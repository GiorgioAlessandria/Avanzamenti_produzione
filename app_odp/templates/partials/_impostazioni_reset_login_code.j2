<div class="row g-4 mb-4">
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="mb-0">Reset login code</h3>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label for="select-user-reset-login-code"
                           class="form-label fw-semibold">
                        Utente
                    </label>
                    <select id="select-user-reset-login-code"
                            class="form-select">
                        <option value="">-- Seleziona un utente --</option>
                        {% for user in registry_users %}
                            <option value="{{ user.id }}">
                                {{ user.username }} - {{ user.current_role_description or user.current_role_name or "Nessun ruolo" }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="mb-4">
                    <label for="reset-login-code-value"
                           class="form-label fw-semibold">
                        Nuovo login code
                    </label>
                    <input type="text"
                           id="reset-login-code-value"
                           class="form-control"
                           minlength="12"
                           autocomplete="off"
                           placeholder="Minimo 12 caratteri alfanumerici">
                    <div class="form-text">
                        Solo lettere e numeri, minimo 12 caratteri.
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="button"
                            class="btn btn-primary"
                            id="btn-reset-login-code-save">
                        Salva nuovo login code
                    </button>

                    <button type="button"
                            class="btn btn-secondary"
                            id="btn-reset-login-code-cancel">
                        Annulla
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="mb-0">Dettaglio reset</h3>
            </div>

            <div class="card-body">
                <div id="reset-login-code-feedback"
                     class="mb-3"></div>

                <div id="reset-login-code-detail">
                    <div class="alert alert-info mb-0">
                        Seleziona un utente e inserisci il nuovo login code.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>