<div class="card shadow-sm h-100 d-flex flex-column"
     style="min-height: 0;">
    <div class="card-header d-flex justify-content-between align-items-center flex-shrink-0">
        <h2 class="h4 mb-0">Materiale necessario</h2>
        <span class="text-muted small">
            Fabbisogno residuo ordini aperti
        </span>
    </div>

    <div class="card-body py-2 d-flex flex-column flex-grow-1 overflow-hidden"
         style="min-height: 0;">
        <div class="table-responsive flex-grow-1 h-100 text-center"
             style="overflow: auto; min-height: 0;">
            <table class="table table-striped table-hover table-sortable table-sticky-wrap align-middle mb-0"
                   id="acquisti_materiale_table">
                <thead>
                <tr>
                    <th data-sort="text">Articolo</th>
                    <th data-sort="text">Var.</th>
                    <th data-sort="text">Descrizione</th>
                    <th data-sort="text">UdM</th>
                    <th data-sort="num">Giacenza</th>
                    <th data-sort="num">Fabbisogno pianificato</th>
                    <th data-sort="num">Fabbisogno impegnato</th>
                    <th data-sort="num">Produzione prevista</th>
                    <th data-sort="num">Rimanenza finale</th>
                    <th data-sort="num">Scorta</th>
                    <th data-sort="num">Lead time</th>
                    <th data-sort="num">Lotto minimo</th>
                    <th data-sort="text">Dettaglio</th>
                </tr>
                </thead>

                <tbody id="tbody_acquisti_materiale">
                {% include "partials/_acquisti_materiale_rows.j2" %}
                </tbody>
            </table>
        </div>
    </div>
</div>