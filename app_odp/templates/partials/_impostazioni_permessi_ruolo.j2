<div class="row g-4 mb-4">
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="mb-0">Modifica permessi ruolo</h3>
            </div>

            <div class="card-body">
                <label for="select-ruolo-permessi"
                       class="form-label fw-semibold">
                    Ruolo
                </label>

                <select id="select-ruolo-permessi"
                        class="form-select">
                    <option value="">-- Seleziona un ruolo --</option>
                    {% for ruolo in permission_role_options %}
                        <option value="{{ ruolo.id }}">
                            {{ ruolo.description or ruolo.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h3 class="mb-0">Dettaglio permessi</h3>
            </div>

            <div class="card-body"
                 id="permessi-ruolo-dettaglio">
                <div class="alert alert-info mb-0">
                    Seleziona un ruolo per visualizzare i permessi.
                </div>
            </div>
        </div>
    </div>
</div>