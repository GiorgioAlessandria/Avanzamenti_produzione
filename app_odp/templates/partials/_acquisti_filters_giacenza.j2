<div class="container-fluid px-0">
    <div class="row g-3 align-items-end">
        <div class="col-12 col-md-6 col-xl-3">
            <label for="filter-acq-giacenza-codart"
                   class="form-label mb-1">
                Codice articolo
            </label>
            <input type="text"
                   id="filter-acq-giacenza-codart"
                   class="form-control js-table-filter"
                   placeholder="Filtra per codice..."
                   data-target-table="acquisti_giacenza_table"
                   data-filter-mode="dataset"
                   data-filter-key="codart"
                   autocomplete="off">
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <label for="filter-acq-giacenza-desart"
                   class="form-label mb-1">
                Descrizione
            </label>
            <input type="text"
                   id="filter-acq-giacenza-desart"
                   class="form-control js-table-filter"
                   placeholder="Filtra per descrizione..."
                   data-target-table="acquisti_giacenza_table"
                   data-filter-mode="dataset"
                   data-filter-key="desart"
                   autocomplete="off">
        </div>

        <div class="col-12 col-md-6 col-xl-2">
            <label for="filter-acq-giacenza-magazzino"
                   class="form-label mb-1">
                Magazzino
            </label>
            <select id="filter-acq-giacenza-magazzino"
                    class="form-select js-table-filter"
                    data-target-table="acquisti_giacenza_table"
                    data-filter-mode="dataset"
                    data-filter-key="codmag">
                <option value="">Tutti</option>
                <option value="0">0</option>
                <option value="10">10</option>
                <option value="13">13</option>
            </select>
        </div>

        <div class="col-12 col-md-6 col-xl-2">
            <div class="form-check mb-2">
                <input class="form-check-input js-table-filter-checkbox"
                       type="checkbox"
                       id="filter-acq-giacenza-negativi"
                       data-target-table="acquisti_giacenza_table"
                       data-filter-key="negative">
                <label class="form-check-label"
                       for="filter-acq-giacenza-negativi">
                    Solo negativi
                </label>
            </div>
        </div>

        <div class="col-12 col-xl-2 text-xl-end">
            <button class="btn btn-outline-success w-100 w-xl-auto"
                    type="button"
                    id="btn-export-acq-giacenza">
                Export Excel
            </button>
        </div>
    </div>
</div>