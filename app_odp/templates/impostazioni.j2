{% extends "base.j2" %}

{% block title %}
    Impostazioni
{% endblock %}

{% block content %}
    <main class="container-fluid mt-4 mb-4">
        {% if show_role_permission_section %}
            {% include "partials/_impostazioni_permessi_ruolo.j2" %}
        {% endif %}

        {% if show_role_assignment_section %}
            {% include "partials/_impostazioni_assegna_ruolo.j2" %}
        {% endif %}

        {% if show_user_abac_section %}
            {% include "partials/_impostazioni_abac.j2" %}
        {% endif %}

        {% if not show_role_assignment_section
              and not show_user_abac_section
              and not show_role_links_section %}
            <div class="alert alert-warning mb-0">
                Non hai permessi per visualizzare le sezioni di configurazione.
            </div>
        {% endif %}
    </main>
{% endblock %}
{% block extra_js %}
    <script id="permission-details-data"
            type="application/json">
    {{ permission_details|tojson }}</script>
    <script id="ruolo-details-data"
            type="application/json">
    {{ ruolo_details|tojson }}</script>
    <script id="user-abac-data"
            type="application/json">
    {{ user_abac_details|tojson }}</script>
    <script id="manageable-users-data"
            type="application/json">
    {{ manageable_users|tojson }}</script>
    <script id="manageable-roles-data"
            type="application/json">
    {{ manageable_roles|tojson }}</script>
    <script id="role-link-details-data"
            type="application/json">
    {{ role_link_details|tojson }}</script>

    <script>
        (() => {
            const selectRuolo = document.getElementById("select-ruolo-impostazioni");
            const placeholder = document.getElementById("placeholder-utenti-ruolo");
            const gruppiUtenti = document.querySelectorAll("[data-role-users]");
            const dettaglio = document.getElementById("impostazioni-dettaglio");

            const roleDataEl = document.getElementById("ruolo-details-data");
            const userAbacEl = document.getElementById("user-abac-data");


            let ruoloDetails = {};
            let userAbacDetails = {};

            try {
                ruoloDetails = JSON.parse(roleDataEl?.textContent || "{}");
            } catch (_) {
                ruoloDetails = {};
            }

            try {
                userAbacDetails = JSON.parse(userAbacEl?.textContent || "{}");
            } catch (_) {
                userAbacDetails = {};
            }

            let selectedUser = null;
            let editMode = false;

            function escapeHtml(value) {
                return String(value ?? "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function nascondiGruppi() {
                gruppiUtenti.forEach((gruppo) => {
                    gruppo.classList.add("d-none");
                });
            }

            function getCurrentAbacForSelection() {
                if (!selectedUser) {
                    return {
                        lavorazioni_ids: [],
                        risorse_ids: []
                    };
                }

                return (
                    userAbacDetails?.[String(selectedUser.roleId)]?.[String(selectedUser.userId)]
                    || {lavorazioni_ids: [], risorse_ids: []}
                );
            }

            function renderCheckboxList(items, selectedIds, emptyMessage, inputName, itemType) {
                if (!Array.isArray(items) || items.length === 0) {
                    return `
                    <div class="alert alert-secondary mb-0">
                        ${escapeHtml(emptyMessage)}
                    </div>
                `;
                }

                const selectedSet = new Set((selectedIds || []).map(v => String(v)));

                return `
                <div class="list-group">
                    ${items.map((item) => {
                    const checked = selectedSet.has(String(item.id)) ? "checked" : "";
                    const inputId = `${inputName}-${item.id}`;

                    return `
                            <label for="${escapeHtml(inputId)}"
                                   class="list-group-item d-flex justify-content-between align-items-start gap-3">
                                <div class="form-check m-0">
                                    <input class="form-check-input js-abac-checkbox"
                                           type="checkbox"
                                           id="${escapeHtml(inputId)}"
                                           value="${escapeHtml(item.id)}"
                                           data-item-type="${escapeHtml(itemType)}"
                                           ${checked}
                                           ${editMode ? "" : "disabled"}>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">${escapeHtml(item.codice || "-")}</div>
                                    <div class="text-muted small">${escapeHtml(item.descrizione || "")}</div>
                                </div>
                            </label>
                        `;
                }).join("")}
                </div>
            `;
            }

            function renderRoleDetail(roleId) {
                if (!dettaglio) return;

                const detail = ruoloDetails[String(roleId)];

                if (!roleId || !detail) {
                    dettaglio.innerHTML = `
                    <div class="alert alert-info mb-0">
                        Seleziona un ruolo per visualizzare lavorazioni e risorse consentite.
                    </div>
                `;
                    return;
                }

                const abac = getCurrentAbacForSelection();

                let userBlock = `
                <div class="mb-3 text-muted">
                    Nessun utente selezionato.
                </div>
            `;

                let actionButtons = "";

                if (selectedUser && String(selectedUser.roleId) === String(roleId)) {
                    userBlock = `
                    <div class="mb-3">
                        <h5 class="mb-1">Utente selezionato: ${escapeHtml(selectedUser.username)}</h5>
                        <div class="text-muted">
                            ${editMode ? "Modalità modifica attiva." : "Modalità sola lettura."}
                        </div>
                    </div>
                `;

                    actionButtons = `
                    <div class="d-flex gap-2 mb-3">
                        <button type="button"
                                class="btn btn-primary"
                                id="btn-abac-edit"
                                ${editMode ? "disabled" : ""}>
                            Modifica
                        </button>

                        <button type="button"
                                class="btn btn-secondary"
                                id="btn-abac-cancel"
                                ${editMode ? "" : "disabled"}>
                            Annulla
                        </button>

                        <button type="button"
                                class="btn btn-success"
                                id="btn-abac-save"
                                ${editMode ? "" : "disabled"}>
                            Salva modifiche
                        </button>
                    </div>
                `;
                }

                dettaglio.innerHTML = `
                <div class="mb-4">
                    <h4 class="mb-1">${escapeHtml(detail.name || "")}</h4>
                    <div class="text-muted">${escapeHtml(detail.description || "")}</div>
                </div>

                ${userBlock}
                ${actionButtons}

                <div class="row g-4">
                    <div class="col-12 col-xl-6">
                        <div class="border rounded p-3 h-100">
                            <h5 class="mb-3">Lavorazioni consentite dal ruolo</h5>
                            ${renderCheckboxList(
                    detail.lavorazioni,
                    abac.lavorazioni_ids,
                    "Nessuna lavorazione associata a questo ruolo.",
                    "lav",
                    "lavorazione"
                )}
                        </div>
                    </div>

                    <div class="col-12 col-xl-6">
                        <div class="border rounded p-3 h-100">
                            <h5 class="mb-3">Risorse consentite dal ruolo</h5>
                            ${renderCheckboxList(
                    detail.risorse,
                    abac.risorse_ids,
                    "Nessuna risorsa associata a questo ruolo.",
                    "ris",
                    "risorsa"
                )}
                        </div>
                    </div>
                </div>
            `;
            }

            function mostraUtentiRuolo(roleId) {
                nascondiGruppi();

                if (!roleId) {
                    if (placeholder) {
                        placeholder.classList.remove("d-none");
                        placeholder.textContent = "Seleziona un ruolo per visualizzare gli utenti associati.";
                    }
                    selectedUser = null;
                    editMode = false;
                    renderRoleDetail("");
                    return;
                }

                const gruppo = document.querySelector(`[data-role-users="${CSS.escape(roleId)}"]`);

                if (!gruppo) {
                    if (placeholder) {
                        placeholder.classList.remove("d-none");
                        placeholder.textContent = "Nessun utente associato a questo ruolo.";
                    }
                    selectedUser = null;
                    editMode = false;
                    renderRoleDetail(roleId);
                    return;
                }

                if (placeholder) placeholder.classList.add("d-none");
                gruppo.classList.remove("d-none");

                gruppo.querySelectorAll(".js-select-user").forEach((btn) => {
                    btn.classList.remove("active");
                });

                selectedUser = null;
                editMode = false;
                renderRoleDetail(roleId);
            }

            function collectCheckedIds(itemType) {
                return Array.from(
                    dettaglio.querySelectorAll(`.js-abac-checkbox[data-item-type="${itemType}"]:checked`)
                ).map(el => Number(el.value));
            }

            async function saveAbacChanges() {
                if (!selectedUser) return;

                const payload = {
                    role_id: Number(selectedUser.roleId),
                    user_id: Number(selectedUser.userId),
                    lavorazioni_ids: collectCheckedIds("lavorazione"),
                    risorse_ids: collectCheckedIds("risorsa"),
                };

                const btnSave = document.getElementById("btn-abac-save");
                if (btnSave) btnSave.disabled = true;

                try {
                    const resp = await fetch("/api/impostazioni/utente-abac", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        credentials: "same-origin",
                        body: JSON.stringify(payload)
                    });

                    let data = {};
                    try {
                        data = await resp.json();
                    } catch (_) {
                        data = {};
                    }

                    if (!resp.ok || data.ok === false) {
                        alert(data.error || "Errore durante il salvataggio delle impostazioni ABAC.");
                        return;
                    }

                    if (!userAbacDetails[String(selectedUser.roleId)]) {
                        userAbacDetails[String(selectedUser.roleId)] = {};
                    }

                    userAbacDetails[String(selectedUser.roleId)][String(selectedUser.userId)] = {
                        id: Number(selectedUser.userId),
                        username: selectedUser.username,
                        lavorazioni_ids: data.lavorazioni_ids || [],
                        risorse_ids: data.risorse_ids || [],
                    };

                    editMode = false;
                    renderRoleDetail(selectedUser.roleId);

                    alert("Modifiche salvate correttamente.");
                } catch (err) {
                    console.error("Errore salvataggio ABAC:", err);
                    alert("Errore di comunicazione con il server.");
                } finally {
                    const newBtnSave = document.getElementById("btn-abac-save");
                    if (newBtnSave && editMode) {
                        newBtnSave.disabled = false;
                    }
                }
            }

            selectRuolo?.addEventListener("change", function () {
                mostraUtentiRuolo(this.value);
            });

            document.addEventListener("click", function (event) {
                const userBtn = event.target.closest(".js-select-user");
                if (userBtn) {
                    const roleId = userBtn.dataset.roleId || "";
                    const userId = userBtn.dataset.userId || "";
                    const username = userBtn.dataset.username || "";

                    const gruppo = document.querySelector(`[data-role-users="${CSS.escape(roleId)}"]`);
                    gruppo?.querySelectorAll(".js-select-user").forEach((item) => {
                        item.classList.remove("active");
                    });
                    userBtn.classList.add("active");

                    selectedUser = {
                        roleId,
                        userId,
                        username
                    };
                    editMode = false;
                    renderRoleDetail(roleId);
                    return;
                }

                const editBtn = event.target.closest("#btn-abac-edit");
                if (editBtn) {
                    editMode = true;
                    renderRoleDetail(selectedUser?.roleId || "");
                    return;
                }

                const cancelBtn = event.target.closest("#btn-abac-cancel");
                if (cancelBtn) {
                    editMode = false;
                    renderRoleDetail(selectedUser?.roleId || "");
                    return;
                }

                const saveBtn = event.target.closest("#btn-abac-save");
                if (saveBtn) {
                    saveAbacChanges();
                }
            });
        })();
    </script>

    <script>
        (() => {
            const usersCountEl = document.getElementById("assign-role-users-count");
            const userSelectEl = document.getElementById("select-user-role-assignment");
            const feedbackEl = document.getElementById("assign-role-feedback");
            const detailEl = document.getElementById("assign-role-detail");

            const usersDataEl = document.getElementById("manageable-users-data");
            const rolesDataEl = document.getElementById("manageable-roles-data");

            let manageableUsers = [];
            let manageableRoles = [];
            let selectedUserId = null;

            try {
                manageableUsers = JSON.parse(usersDataEl?.textContent || "[]");
            } catch (_) {
                manageableUsers = [];
            }

            try {
                manageableRoles = JSON.parse(rolesDataEl?.textContent || "[]");
            } catch (_) {
                manageableRoles = [];
            }

            function normalize(value) {
                return String(value ?? "").trim().toLowerCase();
            }

            function escapeHtml(value) {
                return String(value ?? "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function roleLabel(role) {
                return role?.description || role?.name || "";
            }

            function getSelectedUser() {
                return manageableUsers.find(
                    user => String(user.id) === String(selectedUserId)
                ) || null;
            }

            function getRoleById(roleId) {
                return manageableRoles.find(
                    role => String(role.id) === String(roleId)
                ) || null;
            }

            function showFeedback(type, message) {
                if (!feedbackEl) return;

                if (!message) {
                    feedbackEl.innerHTML = "";
                    return;
                }

                const classMap = {
                    success: "alert-success",
                    danger: "alert-danger",
                    warning: "alert-warning",
                    info: "alert-info",
                };

                const alertClass = classMap[type] || "alert-secondary";

                feedbackEl.innerHTML = `
            <div class="alert ${alertClass} mb-0">
                ${escapeHtml(message)}
            </div>
        `;
            }

            function renderUsersDropdown() {
                if (!userSelectEl) return;

                const users = [...manageableUsers].sort((a, b) =>
                    normalize(a.username).localeCompare(normalize(b.username), "it")
                );

                if (usersCountEl) {
                    usersCountEl.textContent = `${users.length} utente/i disponibili`;
                }

                userSelectEl.innerHTML = `
                    <option value="">-- Seleziona un utente --</option>
                    ${users.map(user => {
                    const ruoloText = user.current_role_description
                        || user.current_role_name
                        || "Senza ruolo";

                    return `
                            <option value="${escapeHtml(user.id)}">
                                ${escapeHtml(user.username)} - ${escapeHtml(ruoloText)}
                            </option>
                        `;
                }).join("")}
                        `;

                if (
                    selectedUserId &&
                    users.some(user => String(user.id) === String(selectedUserId))
                ) {
                    userSelectEl.value = String(selectedUserId);
                } else {
                    selectedUserId = null;
                    userSelectEl.value = "";
                }
            }

            function renderDetail() {
                if (!detailEl) return;

                const user = getSelectedUser();

                if (!user) {
                    detailEl.innerHTML = `
                <div class="alert alert-info mb-0">
                    Seleziona un utente per assegnare o sostituire il ruolo.
                </div>
            `;
                    return;
                }

                const roleOptions = manageableRoles.map(role => `
            <option value="${escapeHtml(role.id)}">
                ${escapeHtml(roleLabel(role))}
            </option>
        `).join("");

                detailEl.innerHTML = `
            <div class="mb-4">
                <h4 class="mb-1">${escapeHtml(user.username)}</h4>
                <div class="text-muted">
                    Ruolo attuale:
                    <strong>${escapeHtml(user.current_role_description || user.current_role_name || "Nessuno")}</strong>
                </div>
            </div>

            <div class="alert alert-warning">
                Il nuovo ruolo sostituisce quello precedente.
            </div>

            <div class="row g-3">
                <div class="col-12 col-lg-8">
                    <label for="select-new-role-user" class="form-label fw-semibold">
                        Nuovo ruolo
                    </label>
                    <select id="select-new-role-user" class="form-select">
                        <option value="">-- Seleziona un ruolo --</option>
                        ${roleOptions}
                    </select>
                </div>

                <div class="col-12 col-lg-4 d-flex align-items-end">
                    <div class="w-100 d-grid gap-2">
                        <button type="button"
                                class="btn btn-primary"
                                id="btn-save-user-role">
                            Assegna ruolo
                        </button>

                        <button type="button"
                                class="btn btn-secondary"
                                id="btn-reset-user-role">
                            Annulla
                        </button>
                    </div>
                </div>
            </div>
        `;
            }

            async function saveAssignedRole() {
                const user = getSelectedUser();
                if (!user) {
                    showFeedback("warning", "Seleziona prima un utente.");
                    return;
                }

                const selectEl = document.getElementById("select-new-role-user");
                const roleId = selectEl?.value || "";

                if (!roleId) {
                    showFeedback("warning", "Seleziona un ruolo da assegnare.");
                    return;
                }

                if (String(user.current_role_id || "") === String(roleId)) {
                    showFeedback("info", "L'utente possiede già questo ruolo.");
                    return;
                }

                const selectedRole = getRoleById(roleId);
                if (!selectedRole) {
                    showFeedback("danger", "Ruolo selezionato non valido.");
                    return;
                }

                const confirmed = window.confirm(
                    `Confermi la sostituzione del ruolo di "${user.username}" con "${roleLabel(selectedRole)}"?`
                );
                if (!confirmed) return;

                const saveBtn = document.getElementById("btn-save-user-role");
                if (saveBtn) saveBtn.disabled = true;

                showFeedback("info", "Salvataggio in corso...");

                try {
                    const resp = await fetch("/api/impostazioni/assegna-ruolo", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        credentials: "same-origin",
                        body: JSON.stringify({
                            user_id: Number(user.id),
                            role_id: Number(roleId)
                        })
                    });

                    let data = {};
                    try {
                        data = await resp.json();
                    } catch (_) {
                        data = {};
                    }

                    if (!resp.ok || data.ok === false) {
                        showFeedback("danger", data.error || "Errore durante l'assegnazione del ruolo.");
                        return;
                    }

                    user.current_role_id = Number(selectedRole.id);
                    user.current_role_name = selectedRole.name || "";
                    user.current_role_description = selectedRole.description || selectedRole.name || "";
                    for (const roleKey of Object.keys(userAbacDetails || {})) {
                        if (userAbacDetails[roleKey] && userAbacDetails[roleKey][String(user.id)]) {
                            delete userAbacDetails[roleKey][String(user.id)];
                        }
                    }

                    renderUsersDropdown();
                    renderDetail();
                    showFeedback("success", data.message || "Ruolo aggiornato correttamente.");
                } catch (err) {
                    console.error("Errore assegnazione ruolo:", err);
                    showFeedback("danger", "Errore di comunicazione con il server.");
                } finally {
                    const newSaveBtn = document.getElementById("btn-save-user-role");
                    if (newSaveBtn) {
                        newSaveBtn.disabled = false;
                    }
                }
            }

            document.addEventListener("click", (event) => {

                const resetBtn = event.target.closest("#btn-reset-user-role");
                if (resetBtn) {
                    showFeedback("", "");
                    renderDetail();
                    return;
                }

                const saveBtn = event.target.closest("#btn-save-user-role");
                if (saveBtn) {
                    saveAssignedRole();
                }
            });
            userSelectEl?.addEventListener("change", function () {
                selectedUserId = this.value || null;
                showFeedback("", "");
                renderDetail();
            });

            renderUsersDropdown();
            renderDetail();
        })();

        (() => {
            const selectRuoloPermessi = document.getElementById("select-ruolo-permessi");
            const dettaglioPermessi = document.getElementById("permessi-ruolo-dettaglio");
            const permissionDataEl = document.getElementById("permission-details-data");

            let permissionDetails = {};
            let editModePermessi = false;
            let selectedRoleIdPermessi = "";

            try {
                permissionDetails = JSON.parse(permissionDataEl?.textContent || "{}");
            } catch (_) {
                permissionDetails = {};
            }

            function escapeHtml(value) {
                return String(value ?? "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function collectCheckedPermissionIds() {
                return Array.from(
                    dettaglioPermessi.querySelectorAll('.js-role-permission-checkbox:checked')
                ).map(el => Number(el.value));
            }

            function renderPermissionCheckboxList(items) {
                if (!Array.isArray(items) || items.length === 0) {
                    return `
                <div class="alert alert-secondary mb-0">
                    Nessun permesso configurabile per questo ruolo.
                </div>
            `;
                }

                return `
            <div class="list-group">
                ${items.map((item) => {
                    const inputId = `perm-${item.id}`;
                    return `
                        <label for="${escapeHtml(inputId)}"
                               class="list-group-item d-flex justify-content-between align-items-start gap-3">
                            <div class="form-check m-0">
                                <input class="form-check-input js-role-permission-checkbox"
                                       type="checkbox"
                                       id="${escapeHtml(inputId)}"
                                       value="${escapeHtml(item.id)}"
                                       ${item.checked ? "checked" : ""}
                                       ${editModePermessi ? "" : "disabled"}>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold">${escapeHtml(item.codice || "-")}</div>
                                <div class="text-muted small">${escapeHtml(item.descrizione || "")}</div>
                            </div>
                        </label>
                    `;
                }).join("")}
            </div>
        `;
            }

            function renderPermissionDetail(roleId) {
                if (!dettaglioPermessi) return;

                const detail = permissionDetails[String(roleId)];

                if (!roleId || !detail) {
                    dettaglioPermessi.innerHTML = `
                <div class="alert alert-info mb-0">
                    Seleziona un ruolo per visualizzare i permessi.
                </div>
            `;
                    return;
                }

                dettaglioPermessi.innerHTML = `
            <div class="mb-4">
                <h4 class="mb-1">${escapeHtml(detail.name || "")}</h4>
                <div class="text-muted">${escapeHtml(detail.description || "")}</div>
            </div>

            <div class="d-flex gap-2 mb-3">
                <button type="button"
                        class="btn btn-primary"
                        id="btn-role-perm-edit"
                        ${editModePermessi ? "disabled" : ""}>
                    Modifica
                </button>

                <button type="button"
                        class="btn btn-secondary"
                        id="btn-role-perm-cancel"
                        ${editModePermessi ? "" : "disabled"}>
                    Annulla
                </button>

                <button type="button"
                        class="btn btn-success"
                        id="btn-role-perm-save"
                        ${editModePermessi ? "" : "disabled"}>
                    Salva modifiche
                </button>
            </div>

            <div class="border rounded p-3 h-100">
                <h5 class="mb-3">Permessi associati al ruolo</h5>
                ${renderPermissionCheckboxList(detail.permissions)}
            </div>
        `;
            }

            async function saveRolePermissions() {
                if (!selectedRoleIdPermessi) return;

                const payload = {
                    role_id: Number(selectedRoleIdPermessi),
                    permission_ids: collectCheckedPermissionIds(),
                };

                const btnSave = document.getElementById("btn-role-perm-save");
                if (btnSave) btnSave.disabled = true;

                try {
                    const resp = await fetch("/api/impostazioni/ruolo-permessi", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        credentials: "same-origin",
                        body: JSON.stringify(payload)
                    });

                    let data = {};
                    try {
                        data = await resp.json();
                    } catch (_) {
                        data = {};
                    }

                    if (!resp.ok || data.ok === false) {
                        alert(data.error || "Errore durante il salvataggio dei permessi ruolo.");
                        return;
                    }

                    if (permissionDetails[String(selectedRoleIdPermessi)]) {
                        const checkedSet = new Set((data.permission_ids || []).map(v => Number(v)));
                        permissionDetails[String(selectedRoleIdPermessi)].permissions =
                            permissionDetails[String(selectedRoleIdPermessi)].permissions.map((perm) => ({
                                ...perm,
                                checked: checkedSet.has(Number(perm.id)),
                            }));
                    }

                    editModePermessi = false;
                    renderPermissionDetail(selectedRoleIdPermessi);

                    alert("Permessi ruolo salvati correttamente.");
                } catch (err) {
                    console.error("Errore salvataggio permessi ruolo:", err);
                    alert("Errore di comunicazione con il server.");
                } finally {
                    const newBtnSave = document.getElementById("btn-role-perm-save");
                    if (newBtnSave && editModePermessi) {
                        newBtnSave.disabled = false;
                    }
                }
            }

            selectRuoloPermessi?.addEventListener("change", function () {
                selectedRoleIdPermessi = this.value || "";
                editModePermessi = false;
                renderPermissionDetail(selectedRoleIdPermessi);
            });

            document.addEventListener("click", function (event) {
                const editBtn = event.target.closest("#btn-role-perm-edit");
                if (editBtn) {
                    editModePermessi = true;
                    renderPermissionDetail(selectedRoleIdPermessi);
                    return;
                }

                const cancelBtn = event.target.closest("#btn-role-perm-cancel");
                if (cancelBtn) {
                    editModePermessi = false;
                    renderPermissionDetail(selectedRoleIdPermessi);
                    return;
                }

                const saveBtn = event.target.closest("#btn-role-perm-save");
                if (saveBtn) {
                    saveRolePermissions();
                }
            });
        })();
        (() => {
            const selectRole = document.getElementById("select-ruolo-link");
            const selectTable = document.getElementById("select-role-link-table");
            const detailEl = document.getElementById("role-link-detail");
            const dataEl = document.getElementById("role-link-details-data");

            let roleLinkDetails = {};
            let selectedRoleId = "";
            let selectedTableKey = "";
            let editMode = false;

            try {
                roleLinkDetails = JSON.parse(dataEl?.textContent || "{}");
            } catch (_) {
                roleLinkDetails = {};
            }

            function escapeHtml(value) {
                return String(value ?? "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function getCurrentTableDetail() {
                const roleDetail = roleLinkDetails[String(selectedRoleId)];
                if (!roleDetail) return null;
                return roleDetail.tables?.[String(selectedTableKey)] || null;
            }

            function collectCheckedIds() {
                return Array.from(
                    detailEl.querySelectorAll(".js-role-link-checkbox:checked")
                ).map(el => Number(el.value));
            }

            function renderItems(items) {
                if (!Array.isArray(items) || items.length === 0) {
                    return `
                <div class="alert alert-secondary mb-0">
                    Nessun elemento disponibile per questa connessione.
                </div>
            `;
                }

                return `
            <div class="list-group">
                ${items.map((item) => {
                    const inputId = `role-link-${item.id}`;
                    return `
                        <label for="${escapeHtml(inputId)}"
                               class="list-group-item d-flex justify-content-between align-items-start gap-3">
                            <div class="form-check m-0">
                                <input class="form-check-input js-role-link-checkbox"
                                       type="checkbox"
                                       id="${escapeHtml(inputId)}"
                                       value="${escapeHtml(item.id)}"
                                       ${item.checked ? "checked" : ""}
                                       ${editMode ? "" : "disabled"}>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold">${escapeHtml(item.codice || "-")}</div>
                                <div class="text-muted small">${escapeHtml(item.descrizione || "")}</div>
                            </div>
                        </label>
                    `;
                }).join("")}
            </div>
        `;
            }

            function renderDetail() {
                if (!detailEl) return;

                const roleDetail = roleLinkDetails[String(selectedRoleId)];
                const tableDetail = getCurrentTableDetail();

                if (!selectedRoleId || !selectedTableKey || !roleDetail || !tableDetail) {
                    detailEl.innerHTML = `
                <div class="alert alert-info mb-0">
                    Seleziona un ruolo e una tabella da modificare.
                </div>
            `;
                    return;
                }

                detailEl.innerHTML = `
            <div class="mb-4">
                <h4 class="mb-1">${escapeHtml(roleDetail.name || "")}</h4>
                <div class="text-muted">${escapeHtml(roleDetail.description || "")}</div>
            </div>

            <div class="mb-3">
                <strong>Connessione selezionata:</strong>
                ${escapeHtml(tableDetail.label || "")}
            </div>

            <div class="d-flex gap-2 mb-3">
                <button type="button"
                        class="btn btn-primary"
                        id="btn-role-link-edit"
                        ${editMode ? "disabled" : ""}>
                    Modifica
                </button>

                <button type="button"
                        class="btn btn-secondary"
                        id="btn-role-link-cancel"
                        ${editMode ? "" : "disabled"}>
                    Annulla
                </button>

                <button type="button"
                        class="btn btn-success"
                        id="btn-role-link-save"
                        ${editMode ? "" : "disabled"}>
                    Salva modifiche
                </button>
            </div>

            <div class="border rounded p-3">
                ${renderItems(tableDetail.items)}
            </div>
        `;
            }

            async function saveRoleLinks() {
                if (!selectedRoleId || !selectedTableKey) return;

                const payload = {
                    role_id: Number(selectedRoleId),
                    table_key: selectedTableKey,
                    selected_ids: collectCheckedIds(),
                };

                const resp = await fetch("/api/impostazioni/ruolo-link", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "X-Requested-With": "XMLHttpRequest",
                    },
                    credentials: "same-origin",
                    body: JSON.stringify(payload),
                });

                let data = {};
                try {
                    data = await resp.json();
                } catch (_) {
                    data = {};
                }

                if (!resp.ok || data.ok === false) {
                    alert(data.error || "Errore salvataggio connessioni ruolo.");
                    return;
                }

                const tableDetail = getCurrentTableDetail();
                if (tableDetail) {
                    const checkedSet = new Set((data.selected_ids || []).map(v => Number(v)));
                    tableDetail.items = tableDetail.items.map(item => ({
                        ...item,
                        checked: checkedSet.has(Number(item.id)),
                    }));
                }

                editMode = false;
                renderDetail();
                alert("Connessioni ruolo salvate correttamente.");
            }

            selectRole?.addEventListener("change", function () {
                selectedRoleId = this.value || "";
                editMode = false;
                renderDetail();
            });

            selectTable?.addEventListener("change", function () {
                selectedTableKey = this.value || "";
                editMode = false;
                renderDetail();
            });

            document.addEventListener("click", function (event) {
                if (event.target.closest("#btn-role-link-edit")) {
                    editMode = true;
                    renderDetail();
                    return;
                }

                if (event.target.closest("#btn-role-link-cancel")) {
                    editMode = false;
                    renderDetail();
                    return;
                }

                if (event.target.closest("#btn-role-link-save")) {
                    saveRoleLinks();
                }
            });
        })();
    </script>
{% endblock %}