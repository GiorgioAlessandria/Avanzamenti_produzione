{% extends "base.j2" %}

{% block title %}Impostazioni{% endblock %}
{% block content %}
    {% if show_user_management_section %}
        <main class="container-fluid mt-4 mb-4">
            <div class="row g-4">
                <!-- Sezione sinistra -->
                <div class="col-12 col-lg-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-header">
                            <h3 class="mb-0">Selezione ruolo e utenti</h3>
                        </div>

                        <div class="card-body">
                            <div class="mb-4">
                                <label for="select-ruolo-impostazioni"
                                       class="form-label fw-semibold">
                                    Ruolo
                                </label>
                                <select id="select-ruolo-impostazioni"
                                        class="form-select">
                                    <option value="">-- Seleziona un ruolo --</option>
                                    {% for ruolo in ruolo_options %}
                                        <option value="{{ ruolo.id }}">
                                            {{ ruolo.name }}
                                            {% if ruolo.description %} - {{ ruolo.description }}{% endif %}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div>
                                <label class="form-label fw-semibold">
                                    Utenti associati al ruolo
                                </label>

                                <div id="box-utenti-ruolo">
                                    <div class="alert alert-secondary mb-0"
                                         id="placeholder-utenti-ruolo">
                                        Seleziona un ruolo per visualizzare gli utenti associati.
                                    </div>

                                    {% for ruolo in ruolo_options %}
                                        <div class="list-group d-none"
                                             data-role-users="{{ ruolo.id }}">
                                            {% for utente in utenti_per_ruolo.get(ruolo.id, []) %}
                                                <button type="button"
                                                        class="list-group-item list-group-item-action js-select-user"
                                                        data-user-id="{{ utente.id }}"
                                                        data-username="{{ utente.username }}"
                                                        data-role-id="{{ ruolo.id }}"
                                                        data-role-name="{{ ruolo.name }}">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span>{{ utente.username }}</span>
                                                        <span class="badge text-bg-light">{{ ruolo.name }}</span>
                                                    </div>
                                                </button>
                                            {% endfor %}
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sezione destra -->
                <div class="col-12 col-lg-8">
                    <div class="card shadow-sm h-100">
                        <div class="card-header">
                            <h3 class="mb-0">Dettaglio impostazioni</h3>
                        </div>

                        <div class="card-body"
                             id="impostazioni-dettaglio">
                            <div class="alert alert-info mb-0">
                                Seleziona prima un ruolo e poi un utente.
                                <br>
                                Qui prepareremo la seconda sezione con lavorazioni e risorse RBAC/ABAC.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    {% endif %}
{% endblock %}

{% block extra_js %}
    <script>
        (() => {
            const selectRuolo = document.getElementById("select-ruolo-impostazioni");
            const placeholder = document.getElementById("placeholder-utenti-ruolo");
            const gruppiUtenti = document.querySelectorAll("[data-role-users]");
            const dettaglio = document.getElementById("impostazioni-dettaglio");

            function nascondiGruppi() {
                gruppiUtenti.forEach((gruppo) => {
                    gruppo.classList.add("d-none");
                });
            }

            function resetDettaglio() {
                if (!dettaglio) return;
                dettaglio.innerHTML = `
                <div class="alert alert-info mb-0">
                    Seleziona prima un ruolo e poi un utente.
                    <br>
                    Qui prepareremo la seconda sezione con lavorazioni e risorse RBAC/ABAC.
                </div>
            `;
            }

            function mostraUtentiRuolo(roleId) {
                nascondiGruppi();

                if (!roleId) {
                    if (placeholder) placeholder.classList.remove("d-none");
                    resetDettaglio();
                    return;
                }

                const gruppo = document.querySelector(`[data-role-users="${CSS.escape(roleId)}"]`);

                if (!gruppo) {
                    if (placeholder) {
                        placeholder.classList.remove("d-none");
                        placeholder.textContent = "Nessun utente associato a questo ruolo.";
                    }
                    resetDettaglio();
                    return;
                }

                if (placeholder) placeholder.classList.add("d-none");
                gruppo.classList.remove("d-none");

                gruppo.querySelectorAll(".js-select-user").forEach((btn) => {
                    btn.classList.remove("active");
                });

                resetDettaglio();
            }

            selectRuolo?.addEventListener("change", function () {
                mostraUtentiRuolo(this.value);
            });

            document.addEventListener("click", function (event) {
                const btn = event.target.closest(".js-select-user");
                if (!btn) return;

                const roleId = btn.dataset.roleId || "";
                const username = btn.dataset.username || "";
                const roleName = btn.dataset.roleName || "";

                const gruppo = document.querySelector(`[data-role-users="${CSS.escape(roleId)}"]`);
                gruppo?.querySelectorAll(".js-select-user").forEach((item) => {
                    item.classList.remove("active");
                });
                btn.classList.add("active");

                if (dettaglio) {
                    dettaglio.innerHTML = `
                    <div class="mb-3">
                        <h4 class="mb-1">Utente selezionato: ${username}</h4>
                        <div class="text-muted">Ruolo selezionato: ${roleName}</div>
                    </div>

                    <div class="alert alert-warning mb-0">
                        Placeholder seconda sezione.
                        <br>
                        Qui inserirò i box di lavorazioni e risorse disponibili lato RBAC,
                        con selezione attiva lato ABAC.
                    </div>
                `;
                }
            });
        })();
    </script>
{% endblock %}
