{% extends "base.j2" %}

{% block title %}Dashboard reparto{% endblock %}

{% block content %}
    <main class="container-fluid mt-4 mb-4">
        <div class="row g-4">
            <div class="col-12 col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <h3 class="mb-0">Selezione utenti subordinati</h3>
                    </div>
                    <div class="card-body">
                        {% if utenti_dashboard %}
                            <div class="list-group"
                                 id="dash-reparto-user-list">
                                {% for utente in utenti_dashboard %}
                                    <button type="button"
                                            class="list-group-item list-group-item-action js-select-dashboard-user {% if loop.first %}active{% endif %}"
                                            data-username="{{ utente.username }}">
                                        <div class="d-flex justify-content-between align-items-center gap-2">
                                            <span class="fw-semibold">{{ utente.username }}</span>
                                            <div class="d-flex align-items-center gap-2">
                                                {% if utente.is_current %}
                                                    <span class="badge text-bg-primary">Tu</span>
                                                {% endif %}
                                                <span class="badge text-bg-light">
                                                    {{ utente.kpi.attivi }} A / {{ utente.kpi.sospesi }} S
                                                </span>
                                            </div>
                                        </div>
                                    </button>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="alert alert-secondary mb-0">
                                Nessun utente subordinato trovato nel tuo perimetro di gestione.
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-8">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <h3 class="mb-0">Riepilogo ordini</h3>
                    </div>
                    <div class="card-body"
                         id="dash-reparto-dettaglio">
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}

{% block extra_js %}
    {{ super() }}
    <script id="dash-reparto-data"
            type="application/json">{{ utenti_dashboard|tojson }}</script>

    <script>
        (() => {
            const usersDataEl = document.getElementById("dash-reparto-data");
            const detail = document.getElementById("dash-reparto-dettaglio");
            const userButtons = document.querySelectorAll(".js-select-dashboard-user");

            let usersData = [];
            try {
                usersData = JSON.parse(usersDataEl?.textContent || "[]");
            } catch (_) {
                usersData = [];
            }

            function formatHours(value) {
                const num = Number(value || 0);
                return `${num.toFixed(2)} m`;
            }

            function escapeHtml(value) {
                return String(value ?? "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/\"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function renderRows(rows) {
                if (!rows?.length) {
                    return `
                        <tr>
                            <td colspan="6" class="text-center text-muted py-3">
                                Nessun ordine in questa sezione.
                            </td>
                        </tr>
                    `;
                }

                return rows.map((row) => `
                    <tr>
                        <td>${escapeHtml(row.ordine)}</td>
                        <td>${escapeHtml(row.descrizione)}</td>
                        <td class="text-end">${escapeHtml(row.quantita)}</td>
                        <td>${escapeHtml(row.risorsa)}</td>
                        <td class="text-end">${escapeHtml(row.tempo_lavorazione)}</td>
                        <td class="text-end">${escapeHtml(row.tempo_attrezzaggio)}</td>
                    </tr>
                `).join("");
            }

            function renderUser(username) {
                if (!detail) return;

                const selected = usersData.find((item) => item.username === username);
                if (!selected) {
                    detail.innerHTML = `
                        <div class="alert alert-info mb-0">
                            Seleziona un utente per visualizzare i suoi ordini attivi e sospesi.
                        </div>
                    `;
                    return;
                }

                detail.innerHTML = `
                    <h4 class="mb-3">Utente selezionato: ${escapeHtml(selected.username)}</h4>

                    <div class="row g-3 mb-4">
                        <div class="col-6 col-xl-3">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body">
                                    <div class="text-muted small">Ordini attivi</div>
                                    <div class="fs-4 fw-semibold">${escapeHtml(selected.kpi.attivi)}</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-xl-3">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body">
                                    <div class="text-muted small">Ordini sospesi</div>
                                    <div class="fs-4 fw-semibold">${escapeHtml(selected.kpi.sospesi)}</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-xl-3">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body">
                                    <div class="text-muted small">Minuti lavorazione previsti</div>
                                    <div class="fs-4 fw-semibold">${escapeHtml(formatHours(selected.kpi.ore_lavorazione))}</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-xl-3">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body">
                                    <div class="text-muted small">Minuti attrezzaggio previsti</div>
                                    <div class="fs-4 fw-semibold">${escapeHtml(formatHours(selected.kpi.ore_attrezzaggio))}</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5 class="mb-2">Ordini attivi</h5>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover table-sm table-sortable">
                                <thead>
                                    <tr>
                                        <th data-sort="text">Numero ordine</th>
                                        <th data-sort="text">Descrizione</th>
                                        <th data-sort="num" class="text-end">Quantità</th>
                                        <th data-sort="text">Risorsa</th>
                                        <th data-sort="num" class="text-end">Tempo lavorazione (m)</th>
                                        <th data-sort="num" class="text-end">Tempo attrezzaggio (m)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${renderRows(selected.ordini_attivi)}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div>
                        <h5 class="mb-2">Ordini in sospeso</h5>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover table-sm table-sortable">
                                <thead>
                                    <tr>
                                        <th data-sort="text">Numero ordine</th>
                                        <th data-sort="text">Descrizione</th>
                                        <th data-sort="num" class="text-end">Quantità</th>
                                        <th data-sort="text">Risorsa</th>
                                        <th data-sort="num" class="text-end">Tempo lavorazione (m)</th>
                                        <th data-sort="num" class="text-end">Tempo attrezzaggio (m)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${renderRows(selected.ordini_sospesi)}
                                </tbody>
                            </table>
                        </div>
                    </div>
                `;
            }

            function setActiveButton(username) {
                userButtons.forEach((button) => {
                    const isActive = button.dataset.username === username;
                    button.classList.toggle("active", isActive);
                });
            }

            userButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    const username = button.dataset.username;
                    setActiveButton(username);
                    renderUser(username);
                });
            });

            if (usersData.length > 0) {
                renderUser(usersData[0].username);
            } else {
                renderUser("");
            }
        })();
    </script>
{% endblock %}
